    "#| echo: true\n",
    "#| warning: false\n",
    "\n",
    "top_states = spark.sql(\"\"\"\n",
    "SELECT\n",
    "    STATE_NAME AS state_name,\n",
    "    COUNT(*) AS job_count\n",
    "FROM raw_jobs_clean\n",
    "WHERE STATE_NAME IS NOT NULL\n",
    "GROUP BY STATE_NAME\n",
    "ORDER BY job_count DESC\n",
    "LIMIT 10\n",
    "\"\"\").toPandas()\n",
    "\n",
    "display(style_table(top_states, {\n",
    "    \"job_count\": \"{:,.0f}\"\n",
    "}))"
