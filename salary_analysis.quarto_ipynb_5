    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "ai_premium_state = spark.sql(\"\"\"\n",
        "WITH state_salary AS (\n",
        "    SELECT\n",
        "        l.state_name,\n",
        "        CASE\n",
        "            WHEN a.job_id IS NOT NULL THEN 'AI-related'\n",
        "            ELSE 'Non-AI'\n",
        "        END AS career_type,\n",
        "        AVG(CAST(j.salary AS DOUBLE)) AS avg_salary,\n",
        "        COUNT(*) AS postings\n",
        "    FROM job_postings j\n",
        "    LEFT JOIN ai_job_ids a\n",
        "        ON j.id = a.job_id\n",
        "    LEFT JOIN locations l\n",
        "        ON j.location_id = l.location_id\n",
        "    WHERE\n",
        "        j.salary IS NOT NULL\n",
        "        AND CAST(j.salary AS DOUBLE) > 0\n",
        "        AND l.state_name IS NOT NULL\n",
        "    GROUP BY\n",
        "        l.state_name,\n",
        "        CASE\n",
        "            WHEN a.job_id IS NOT NULL THEN 'AI-related'\n",
        "            ELSE 'Non-AI'\n",
        "        END\n",
        "),\n",
        "\n",
        "pivoted AS (\n",
        "    SELECT\n",
        "        state_name,\n",
        "        MAX(CASE WHEN career_type = 'AI-related'\n",
        "                 THEN avg_salary END) AS ai_salary,\n",
        "        MAX(CASE WHEN career_type = 'Non-AI'\n",
        "                 THEN avg_salary END) AS non_ai_salary\n",
        "    FROM state_salary\n",
        "    GROUP BY state_name\n",
        ")\n",
        "\n",
        "SELECT\n",
        "    state_name,\n",
        "    ROUND(ai_salary,0) AS ai_salary,\n",
        "    ROUND(non_ai_salary,0) AS non_ai_salary,\n",
        "    ROUND(ai_salary - non_ai_salary,0) AS ai_salary_premium,\n",
        "    ROUND(\n",
        "        ((ai_salary - non_ai_salary)\n",
        "         / non_ai_salary) * 100,\n",
        "        1\n",
        "    ) AS premium_pct\n",
        "FROM pivoted\n",
        "WHERE\n",
        "    ai_salary IS NOT NULL\n",
        "    AND non_ai_salary IS NOT NULL\n",
        "\"\"\")\n",
        "\n",
        "ai_premium_state_pd = ai_premium_state.toPandas()\n",
        "\n",
        "from us import states\n",
        "\n",
        "ai_premium_state_pd[\"state_code\"] = (\n",
        "    ai_premium_state_pd[\"state_name\"]\n",
        "    .apply(lambda x: states.lookup(x).abbr if states.lookup(x) else None)\n",
        ")\n",
        "\n",
        "import plotly.express as px\n",
        "\n",
        "ai_map = state_salary_pd[\n",
        "    state_salary_pd[\"career_type\"] == \"AI-related\"\n",
        "]\n",
        "\n",
        "fig = px.choropleth(\n",
        "    ai_premium_state_pd,\n",
        "    locations=\"state_code\",\n",
        "    locationmode=\"USA-states\",\n",
        "    color=\"ai_salary_premium\",\n",
        "    scope=\"usa\",\n",
        "    hover_name=\"state_name\",\n",
        "    hover_data={\n",
        "        \"ai_salary\": \":,.0f\",\n",
        "        \"non_ai_salary\": \":,.0f\",\n",
        "        \"premium_pct\": \":.1f\"\n",
        "    },\n",
        "    color_continuous_scale=\"RdYlGn\",\n",
        "    title=\"AI Salary Premium by State\"\n",
        ")\n",
        "\n",
        "fig.update_layout(\n",
        "    template=\"plotly_white\",\n",
        "    height=550,\n",
        "    title=dict(\n",
        "        text=\"AI Salary Premium by State\",\n",
        "        x=0.02\n",
        "    ),\n",
        "    coloraxis_colorbar=dict(\n",
        "        title=\"Premium ($)\"\n",
        "    )\n",
        ")\n",
        "\n",
        "fig.show()"
      ],
