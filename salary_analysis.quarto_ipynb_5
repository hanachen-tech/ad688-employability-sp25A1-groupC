        "def style_table(df, format_dict=None):\n",
        "\n",
        "    styled = df.style\n",
        "\n",
        "    if format_dict is not None:\n",
        "\n",
        "        styled = styled.format(format_dict)\n",
        "\n",
        "    styled = styled.set_properties(**{\n",
        "\n",
        "        \"text-align\": \"left\",\n",
        "\n",
        "        \"white-space\": \"normal\",\n",
        "\n",
        "        \"border\": \"1px solid black\"\n",
        "\n",
        "    }).set_table_styles([\n",
        "\n",
        "        {\n",
        "\n",
        "            \"selector\": \"th\",\n",
        "\n",
        "            \"props\": [\n",
        "\n",
        "                (\"border\", \"1px solid black\"),\n",
        "\n",
        "                (\"text-align\", \"left\"),\n",
        "\n",
        "                (\"background-color\", \"#f2f2f2\")\n",
        "\n",
        "            ]\n",
        "\n",
        "        },\n",
        "\n",
        "        {\n",
        "\n",
        "            \"selector\": \"td\",\n",
        "\n",
        "            \"props\": [\n",
        "\n",
        "                (\"border\", \"1px solid black\"),\n",
        "\n",
        "                (\"padding\", \"6px\")\n",
        "\n",
        "            ]\n",
        "\n",
        "        },\n",
        "\n",
        "        {\n",
        "\n",
        "            \"selector\": \"table\",\n",
        "\n",
        "            \"props\": [\n",
        "\n",
        "                (\"border-collapse\", \"collapse\")\n",
        "\n",
        "            ]\n",
        "\n",
        "        }\n",
        "\n",
        "    ])\n",
        "\n",
        "    return styled"
      ],
