        "# Exploratory Data Analysis\n",
        "\n",
        "## Overview\n",
        "\n",
        "This page explores the cleaned Lightcast job postings dataset created in the data preparation step. The purpose of this exploratory analysis is to understand the overall size of the dataset, salary availability, remote-work categories, geographic distribution, and industry distribution before moving into the main research analysis.\n",
        "\n",
        "## 1. Load Cleaned Data"
      ],
      "id": "e4444de8"
    },
    {
      "cell_type": "code",
      "metadata": {
        "message": false
      },
      "source": [
        "#| echo: true\n",
        "#| warning: false\n",
        "\n",
        "from pyspark.sql import SparkSession\n",
        "from IPython.display import display\n",
        "import pandas as pd\n",
        "import plotly.express as px\n",
        "\n",
        "spark = SparkSession.builder \\\n",
        "    .config(\"spark.driver.host\", \"localhost\") \\\n",
        "    .appName(\"EDAJobMarket\") \\\n",
        "    .getOrCreate()\n",
        "\n",
        "spark.catalog.clearCache()\n",
        "\n",
        "df_clean = spark.read.parquet(\"data/cleaned/lightcast_cleaned.parquet\")\n",
        "df_clean.createOrReplaceTempView(\"raw_jobs_clean\")\n",
        "\n",
        "def style_table(df, format_dict=None):\n",
        "    styled = df.style\n",
        "    if format_dict is not None:\n",
        "        styled = styled.format(format_dict)\n",
        "    styled = styled.set_properties(**{\n",
        "        \"text-align\": \"left\",\n",
        "        \"white-space\": \"normal\",\n",
        "        \"border\": \"1px solid #ddd\",\n",
        "        \"padding\": \"6px\"\n",
        "    }).set_table_styles([\n",
        "        {\"selector\": \"th\", \"props\": [\n",
        "            (\"background-color\", \"#f6f8fa\"),\n",
        "            (\"color\", \"#24324b\"),\n",
        "            (\"font-weight\", \"bold\"),\n",
        "            (\"border\", \"1px solid #ddd\"),\n",
        "            (\"padding\", \"8px\")\n",
        "        ]},\n",
        "        {\"selector\": \"td\", \"props\": [\n",
        "            (\"border\", \"1px solid #ddd\"),\n",
        "            (\"padding\", \"6px\")\n",
        "        ]},\n",
        "        {\"selector\": \"table\", \"props\": [\n",
        "            (\"border-collapse\", \"collapse\"),\n",
        "            (\"width\", \"100%\")\n",
        "        ]}\n",
        "    ])\n",
        "    return styled\n",
        "\n",
        "print(\"Cleaned rows:\", df_clean.count())\n",
        "print(\"Cleaned columns:\", len(df_clean.columns))"
      ],
      "id": "9ad9cc62",
      "execution_count": null,
      "outputs": []
    },
