      "source": [
        "#| echo: true\n",
        "#| warning: false\n",
        "\n",
        "remote_summary = spark.sql(\"\"\"\n",
        "SELECT\n",
        "    CASE\n",
        "        WHEN REMOTE_TYPE_NAME IS NULL OR REMOTE_TYPE_NAME = '[None]' THEN 'Unknown'\n",
        "        ELSE REMOTE_TYPE_NAME\n",
        "    END AS remote_type,\n",
        "    COUNT(*) AS job_count\n",
        "FROM raw_jobs_clean\n",
        "GROUP BY\n",
        "    CASE\n",
        "        WHEN REMOTE_TYPE_NAME IS NULL OR REMOTE_TYPE_NAME = '[None]' THEN 'Unknown'\n",
        "        ELSE REMOTE_TYPE_NAME\n",
        "    END\n",
        "ORDER BY job_count DESC\n",
        "\"\"\").toPandas()\n",
        "\n",
        "remote_summary[\"job_share\"] = (\n",
        "    remote_summary[\"job_count\"] / remote_summary[\"job_count\"].sum()\n",
        ")\n",
        "\n",
        "display(style_table(remote_summary, {\n",
        "    \"job_count\": \"{:,.0f}\",\n",
        "    \"job_share\": \"{:.1%}\"\n",
        "}))"
