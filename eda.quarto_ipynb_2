        "## 4. Salary Availability After Imputation\n",
        "\n",
        "This section checks salary coverage using `ANALYSIS_SALARY_INDUSTRY_IMPUTED`, which combines observed salary values with qualified industry-median imputed salary values. This variable is used as the main salary variable for later salary-based analysis."
      ],
      "id": "96cf4162"
    },
    {
      "cell_type": "code",
      "metadata": {
        "message": false
      },
      "source": [
        "#| echo: true\n",
        "#| warning: false\n",
        "\n",
        "salary_availability = spark.sql(\"\"\"\n",
        "SELECT\n",
        "    CASE\n",
        "        WHEN ANALYSIS_SALARY_INDUSTRY_IMPUTED IS NOT NULL\n",
        "             AND ANALYSIS_SALARY_INDUSTRY_IMPUTED > 0\n",
        "        THEN 'Salary Available'\n",
        "        ELSE 'Salary Missing'\n",
        "    END AS salary_status,\n",
        "    COUNT(*) AS job_count,\n",
        "    ROUND(COUNT(*) / (SELECT COUNT(*) FROM raw_jobs_clean) * 100, 2) AS job_share\n",
        "FROM raw_jobs_clean\n",
        "GROUP BY\n",
        "    CASE\n",
        "        WHEN ANALYSIS_SALARY_INDUSTRY_IMPUTED IS NOT NULL\n",
        "             AND ANALYSIS_SALARY_INDUSTRY_IMPUTED > 0\n",
        "        THEN 'Salary Available'\n",
        "        ELSE 'Salary Missing'\n",
        "    END\n",
        "ORDER BY job_count DESC\n",
        "\"\"\").toPandas()\n",
        "\n",
        "display(style_table(salary_availability, {\n",
        "    \"job_count\": \"{:,.0f}\",\n",
        "    \"job_share\": \"{:.2f}%\"\n",
        "}))"
      ],
      "id": "d8482feb",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "message": false
      },
      "source": [
        "#| echo: true\n",
        "#| warning: false\n",
        "\n",
        "fig_salary = px.bar(\n",
        "    salary_availability,\n",
        "    x=\"salary_status\",\n",
        "    y=\"job_count\",\n",
        "    text=\"job_count\",\n",
