    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "ai_vs_non_ai_salary = spark.sql(\"\"\"\n",
        "SELECT\n",
        "    CASE\n",
        "        WHEN a.job_id IS NOT NULL THEN 'AI-related'\n",
        "        ELSE 'Non-AI'\n",
        "    END AS career_type,\n",
        "    ROUND(AVG(CAST(j.salary AS DOUBLE)), 2) AS avg_salary,\n",
        "    PERCENTILE_APPROX(CAST(j.salary AS DOUBLE), 0.5) AS median_salary,\n",
        "    COUNT(DISTINCT j.id) AS job_count,\n",
        "    COUNT(DISTINCT j.title_clean) AS unique_job_titles\n",
        "FROM job_postings j\n",
        "LEFT JOIN ai_job_ids a\n",
        "    ON j.id = a.job_id\n",
        "WHERE\n",
        "    j.salary IS NOT NULL\n",
        "    AND CAST(j.salary AS DOUBLE) > 0\n",
        "GROUP BY\n",
        "    CASE\n",
        "        WHEN a.job_id IS NOT NULL THEN 'AI-related'\n",
        "        ELSE 'Non-AI'\n",
        "    END\n",
        "ORDER BY\n",
        "    avg_salary DESC\n",
        "\"\"\")\n",
        "\n",
        "ai_vs_non_ai_salary_pd = ai_vs_non_ai_salary.toPandas()\n",
        "\n",
        "ai_vs_non_ai_salary_pd[\"job_share\"] = (\n",
        "    ai_vs_non_ai_salary_pd[\"job_count\"] / ai_vs_non_ai_salary_pd[\"job_count\"].sum()\n",
        ")\n",
        "\n",
        "style_table(ai_vs_non_ai_salary_pd, {\n",
        "    \"avg_salary\": \"${:,.2f}\",\n",
        "    \"median_salary\": \"${:,.2f}\",\n",
        "    \"job_count\": \"{:,.0f}\",\n",
        "    \"unique_job_titles\": \"{:,.0f}\",\n",
        "    \"job_share\": \"{:.1%}\"\n",
        "})"
