      "source": [
        "industry_salary_monthly = spark.sql(\"\"\"\n",
        "SELECT\n",
        "    i.naics_2022_6_name AS industry,\n",
        "    MONTH(j.posted_date) AS month_num,\n",
        "    DATE_FORMAT(j.posted_date, 'MMM') AS month,\n",
        "    ROUND(\n",
        "        AVG(CAST(j.salary AS DOUBLE)),0) AS avg_salary\n",
        "FROM job_postings j\n",
        "LEFT JOIN industries i\n",
        "    ON j.industry_id = i.industry_id\n",
        "WHERE\n",
        "    YEAR(j.posted_date) = 2024\n",
        "    AND j.salary IS NOT NULL\n",
        "GROUP BY\n",
        "    i.naics_2022_6_name,\n",
        "    MONTH(j.posted_date), DATE_FORMAT(j.posted_date, 'MMM')\n",
        "ORDER BY industry, MONTH(j.posted_date)\n",
        "\"\"\")\n",
        "\n",
        "industry_salary_monthly_pd = industry_salary_monthly.toPandas()\n",
        "\n",
        "top_industries = (\n",
        "    industry_salary_monthly_pd\n",
        "    .groupby(\"industry\")[\"avg_salary\"]\n",
        "    .mean()\n",
        "    .nlargest(12)\n",
        "    .index\n",
        ")\n",
        "\n",
        "plot_df = industry_salary_monthly_pd[\n",
        "    industry_salary_monthly_pd[\"industry\"].isin(top_industries)\n",
        "]\n",
        "month_order = [\n",
        "    \"May\", \"Jun\",\n",
        "    \"Jul\", \"Aug\", \"Sep\"\n",
        "]\n",
        "\n",
        "fig_industry = px.line(\n",
        "    plot_df,\n",
        "    x=\"month\",\n",
        "    y=\"avg_salary\",\n",
        "    color=\"industry\",\n",
        "    markers=True,\n",
        "    category_orders={\"month\": month_order},\n",
        "    title=\"Monthly Salary Trends by Industry (2024)\"\n",
        ")\n",
