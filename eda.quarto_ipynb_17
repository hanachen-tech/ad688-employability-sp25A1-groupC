      "source": [
        "#| echo: fenced\n",
        "#| code-fold: true\n",
        "#| code-summary: Show code\n",
        "#| warning: false\n",
        "\n",
        "occupation_salary = spark.sql(\"\"\"\n",
        "WITH top_occ AS (\n",
        "    SELECT\n",
        "        o.specialized_occupation_name,\n",
        "        COUNT(*) AS job_count\n",
        "    FROM job_postings j\n",
        "    LEFT JOIN occupations o\n",
        "        ON j.occupation_id = o.occupation_id\n",
        "    WHERE j.salary IS NOT NULL\n",
        "      AND j.salary > 0\n",
        "      AND j.salary <= 500000\n",
        "      AND o.specialized_occupation_name IS NOT NULL\n",
        "    GROUP BY o.specialized_occupation_name\n",
        "    ORDER BY job_count DESC\n",
        "    LIMIT 8\n",
        ")\n",
        "SELECT\n",
        "    o.specialized_occupation_name,\n",
        "    j.salary\n",
        "FROM job_postings j\n",
        "LEFT JOIN occupations o\n",
