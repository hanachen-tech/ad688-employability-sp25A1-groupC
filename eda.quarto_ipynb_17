        "\n",
        "# Exploratory Data Analysis\n",
        "\n",
        "## Overview\n",
        "\n",
        "This page explores the cleaned Lightcast job postings dataset created during the data preparation step. The purpose of this exploratory analysis is to understand the dataset size, salary availability, missing salary patterns, remote-work categories, geographic concentration, industry concentration, occupation mix, and skill demand before moving into the main salary analysis.\n",
        "\n",
        "## 1. Load Cleaned Data"
      ],
      "id": "2661fc7d"
    },
    {
      "cell_type": "code",
      "metadata": {
        "message": false
      },
      "source": [
        "#| echo: false\n",
        "#| warning: false\n",
        "\n",
        "from pyspark.sql import SparkSession\n",
        "from pyspark.sql.functions import col\n",
        "from IPython.display import display\n",
        "import pandas as pd\n",
        "import plotly.express as px\n",
        "\n",
        "spark = (\n",
        "    SparkSession.builder\n",
        "    .config(\"spark.driver.host\", \"localhost\")\n",
        "    .config(\"spark.driver.memory\", \"2g\")\n",
        "    .config(\"spark.executor.memory\", \"2g\")\n",
        "    .config(\"spark.sql.shuffle.partitions\", \"8\")\n",
        "    .appName(\"EDAJobMarket\")\n",
        "    .getOrCreate()\n",
        ")\n",
        "\n",
        "spark.catalog.clearCache()\n",
        "spark.sparkContext.setLogLevel(\"ERROR\")\n",
        "\n",
        "# Load prepared tables created by data_cleaning.qmd\n",
        "job_postings_df = spark.read.parquet(\"data/prepared/job_postings.parquet\")\n",
        "companies_df = spark.read.parquet(\"data/prepared/companies.parquet\")\n",
        "industries_df = spark.read.parquet(\"data/prepared/industries.parquet\")\n",
        "locations_df = spark.read.parquet(\"data/prepared/locations.parquet\")\n",
        "occupations_df = spark.read.parquet(\"data/prepared/occupations.parquet\")\n",
        "skills_df = spark.read.parquet(\"data/prepared/skills.parquet\")\n",
        "job_skill_matches_df = spark.read.parquet(\"data/prepared/job_skill_matches.parquet\")\n",
        "ai_job_ids = spark.read.parquet(\"data/prepared/ai_job_ids.parquet\")\n",
        "jobs_with_ai = spark.read.parquet(\"data/prepared/jobs_with_ai.parquet\")\n",
        "salary_regression_data = spark.read.parquet(\"data/prepared/salary_regression_data.parquet\")\n",
        "salary_classification_data = spark.read.parquet(\"data/prepared/salary_classification_data.parquet\")\n",
        "\n",
        "from pyspark.sql.functions import col\n",
        "\n",
        "education_df = (\n",
        "    spark.read.parquet(\"data/cleaned/lightcast_cleaned.parquet\")\n",
        "    .select(\n",
        "        col(\"ID\").alias(\"id\"),\n",
        "        col(\"EDUCATION_LEVELS_NAME\").alias(\"education_level\")\n",
        "    )\n",
        "    .dropDuplicates([\"id\"])\n",
        ")\n",
        "\n",
        "education_df.createOrReplaceTempView(\"education_levels\")\n",
        "\n",
        "# Register Spark SQL views\n",
        "job_postings_df.createOrReplaceTempView(\"job_postings\")\n",
        "companies_df.createOrReplaceTempView(\"companies\")\n",
        "industries_df.createOrReplaceTempView(\"industries\")\n",
        "locations_df.createOrReplaceTempView(\"locations\")\n",
        "occupations_df.createOrReplaceTempView(\"occupations\")\n",
        "skills_df.createOrReplaceTempView(\"skills\")\n",
        "job_skill_matches_df.createOrReplaceTempView(\"job_skill_matches\")\n",
        "ai_job_ids.createOrReplaceTempView(\"ai_job_ids\")\n",
        "jobs_with_ai.createOrReplaceTempView(\"jobs_with_ai\")\n",
        "salary_regression_data.createOrReplaceTempView(\"salary_regression_data\")\n",
        "salary_classification_data.createOrReplaceTempView(\"salary_classification_data\")\n",
        "\n",
        "def style_table(df, format_dict=None):\n",
        "    styled = df.style\n",
        "    if format_dict is not None:\n",
        "        styled = styled.format(format_dict)\n",
        "    styled = styled.set_properties(**{\n",
        "        \"text-align\": \"left\",\n",
        "        \"white-space\": \"normal\",\n",
        "        \"border\": \"1px solid #ddd\",\n",
        "        \"padding\": \"6px\"\n",
        "    }).set_table_styles([\n",
        "        {\"selector\": \"th\", \"props\": [\n",
        "            (\"background-color\", \"#f6f8fa\"),\n",
        "            (\"color\", \"#24324b\"),\n",
        "            (\"font-weight\", \"bold\"),\n",
        "            (\"border\", \"1px solid #ddd\"),\n",
        "            (\"padding\", \"8px\")\n",
        "        ]},\n",
        "        {\"selector\": \"td\", \"props\": [\n",
        "            (\"border\", \"1px solid #ddd\"),\n",
        "            (\"padding\", \"6px\")\n",
        "        ]},\n",
        "        {\"selector\": \"table\", \"props\": [\n",
        "            (\"border-collapse\", \"collapse\"),\n",
        "            (\"width\", \"100%\")\n",
        "        ]}\n",
        "    ])\n",
        "    return styled\n",
        "\n",
        "print(\"Prepared job postings rows:\", job_postings_df.count())\n",
        "print(\"Regression-ready rows:\", salary_regression_data.count())\n",
        "print(\"Classification-ready rows:\", salary_classification_data.count())"
      ],
      "id": "3059f802",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 2. Cleaned Dataset Summary\n",
        "\n",
        "Why this table was chosen:  \n",
        "This summary provides a high-level view of the cleaned dataset before deeper analysis. It shows the scale of the job posting data, including the number of postings, companies, locations, industries, and occupations."
      ],
      "id": "84ac2e2e"
    },
    {
      "cell_type": "code",
      "metadata": {
        "message": false
      },
      "source": [
        "#| echo: false\n",
        "#| warning: false\n",
        "\n",
        "summary = spark.sql(\"\"\"\n",
        "SELECT\n",
        "    COUNT(*) AS total_job_postings,\n",
        "    COUNT(DISTINCT id) AS unique_job_ids,\n",
        "    COUNT(DISTINCT company_id) AS unique_companies,\n",
        "    COUNT(DISTINCT location_id) AS unique_locations,\n",
        "    COUNT(DISTINCT industry_id) AS unique_industries,\n",
        "    COUNT(DISTINCT occupation_id) AS unique_occupations\n",
        "FROM job_postings\n",
        "\"\"\").toPandas()\n",
        "\n",
        "display(style_table(summary, {\n",
        "    \"total_job_postings\": \"{:,.0f}\",\n",
        "    \"unique_job_ids\": \"{:,.0f}\",\n",
        "    \"unique_companies\": \"{:,.0f}\",\n",
        "    \"unique_locations\": \"{:,.0f}\",\n",
        "    \"unique_industries\": \"{:,.0f}\",\n",
        "    \"unique_occupations\": \"{:,.0f}\"\n",
        "}))"
      ],
      "id": "5d44cc8e",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "**Key insight:** The cleaned dataset contains 72,476 job postings across 12,302 companies, 4,837 locations, 814 industries, and 11 occupation categories. This provides broad coverage of the job market, but the salary analysis depends on the smaller subset of postings with usable salary information.\n",
        "\n",
        "## 3. Salary Availability in the Dataset\n",
        "\n",
        "Why this visualization was chosen:  \n",
        "Salary is the main compensation variable in this project, so the first step is to understand how many postings have usable salary information after imputation."
      ],
      "id": "4f6f5977"
    },
    {
      "cell_type": "code",
      "metadata": {
        "message": false
      },
      "source": [
        "#| echo: false\n",
        "#| warning: false\n",
        "\n",
        "salary_availability = spark.sql(\"\"\"\n",
        "SELECT\n",
        "    CASE\n",
        "        WHEN salary IS NOT NULL AND salary > 0\n",
        "        THEN 'Salary Available'\n",
        "        ELSE 'Salary Missing'\n",
        "    END AS salary_status,\n",
        "    COUNT(*) AS job_count,\n",
        "    ROUND(COUNT(*) / (SELECT COUNT(*) FROM job_postings) * 100, 2) AS job_share\n",
        "FROM job_postings\n",
        "GROUP BY\n",
        "    CASE\n",
        "        WHEN salary IS NOT NULL AND salary > 0\n",
        "        THEN 'Salary Available'\n",
        "        ELSE 'Salary Missing'\n",
        "    END\n",
        "ORDER BY job_count DESC\n",
        "\"\"\").toPandas()\n",
        "\n",
        "display(style_table(salary_availability, {\n",
        "    \"job_count\": \"{:,.0f}\",\n",
        "    \"job_share\": \"{:.2f}%\"\n",
        "}))"
      ],
      "id": "a0fc936c",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "message": false
      },
      "source": [
        "#| echo: false\n",
        "#| warning: false\n",
        "\n",
        "fig_salary = px.bar(\n",
        "    salary_availability,\n",
        "    x=\"salary_status\",\n",
        "    y=\"job_count\",\n",
        "    text=\"job_count\",\n",
        "    color=\"salary_status\",\n",
