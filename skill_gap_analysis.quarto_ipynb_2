    "# Calculate team average for each skill\n",
    "team_avg_skills = df_skills_indexed.mean().sort_values(ascending=False)\n",
    "\n",
    "# Create comparison DataFrame\n",
    "comparison_df = pd.DataFrame({\n",
    "    'Team Average': team_avg_skills,\n",
    "    'Market Demand': [job_skill_frequency.get(skill, 0) for skill in team_avg_skills.index]\n",
    "})\n",
    "\n",
    "# Normalize market demand to 1-5 scale\n",
    "comparison_df['Market Demand (1-5)'] = (comparison_df['Market Demand'] / 100) * 5\n",
    "comparison_df['Gap'] = comparison_df['Market Demand (1-5)'] - comparison_df['Team Average']\n",
    "comparison_df['Gap Category'] = comparison_df['Gap'].apply(\n",
    "    lambda x: 'High Priority' if x > 1.5 else ('Medium Priority' if x > 0.5 else 'Low Priority')\n",
    ")\n",
    "\n",
    "# Create interactive grouped bar chart\n",
    "fig_comparison = go.Figure(data=[\n",
    "    go.Bar(\n",
    "        name='Team Average',\n",
    "        x=comparison_df.index,\n",
    "        y=comparison_df['Team Average'],\n",
    "        marker=dict(color='skyblue'),\n",
    "        hovertemplate='<b>%{x}</b><br>Team: %{y:.1f}<extra></extra>'\n",
    "    ),\n",
    "    go.Bar(\n",
    "        name='Market Demand (1-5)',\n",
    "        x=comparison_df.index,\n",
    "        y=comparison_df['Market Demand (1-5)'],\n",
    "        marker=dict(color='coral'),\n",
    "        hovertemplate='<b>%{x}</b><br>Market: %{y:.1f}<extra></extra>'\n",
    "    )\n",
    "])\n",
    "\n",
    "fig_comparison.update_layout(\n",
    "    title=\"Team Skills vs Market Demands (Interactive)\",\n",
    "    xaxis_title=\"Skills\",\n",
    "    yaxis_title=\"Level (1-5)\",\n",
    "    barmode='group',\n",
    "    height=500,\n",
    "    width=1200,\n",
    "    hovermode='x unified',\n",
    "    legend=dict(\n",
    "        x=0.01,\n",
    "        y=0.99,\n",
    "        bgcolor='rgba(255, 255, 255, 0.8)'\n",
    "    )\n",
    ")\n",
    "\n",
    "fig_comparison.show()"
   ]
