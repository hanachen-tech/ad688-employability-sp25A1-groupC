    "    colorscale='RdYlGn',\n",
    "    text=df_skills_indexed.values,\n",
    "    texttemplate='%{text}',\n",
    "    textfont={\"size\": 12},\n",
    "    hovertemplate='<b>%{y}</b><br>%{x}: %{z}<extra></extra>',\n",
