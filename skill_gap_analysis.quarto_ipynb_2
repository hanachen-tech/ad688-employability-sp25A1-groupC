    "import plotly.graph_objects as go\n",
    "import plotly.express as px\n",
    "\n",
    "# Filter high priority skills\n",
    "high_priority = comparison_df[comparison_df['Gap Category'] == 'High Priority'].sort_values('Gap', ascending=True)\n",
    "\n",
    "if len(high_priority) > 0:\n",
    "    # Create interactive chart for high priority skills\n",
    "    fig_priority = go.Figure(data=[\n",
    "        go.Bar(\n",
    "            y=high_priority.index,\n",
    "            x=high_priority['Gap'],\n",
    "            orientation='h',\n",
    "            marker=dict(\n",
    "                color=high_priority['Gap'],\n",
    "                colorscale='Reds',\n",
    "                showscale=True,\n",
    "                colorbar=dict(title=\"Gap Size\")\n",
    "            ),\n",
    "            text=high_priority['Gap'].round(1),\n",
    "            textposition='auto',\n",
    "            hovertemplate='<b>%{y}</b><br>Gap: %{x:.1f} levels<extra></extra>'\n",
    "        )\n",
    "    ])\n",
    "\n",
    "    fig_priority.update_layout(\n",
    "        title=\"High Priority Skills to Learn (Gap Size)\",\n",
    "        xaxis_title=\"Skill Gap (levels)\",\n",
    "        yaxis_title=\"Skills\",\n",
    "        height=400,\n",
    "        width=800,\n",
    "        showlegend=False,\n",
    "        hovermode='closest'\n",
    "    )\n",
    "\n",
    "    fig_priority.show()\n",
    "    \n",
    "    print(\"\\nHigh Priority Skills:\")\n",
    "    for skill in high_priority.index:\n",
    "        gap = high_priority.loc[skill, 'Gap']\n",
    "        print(f\"  • {skill}: Gap = {gap:.1f} levels\")\n",
    "else:\n",
    "    print(\"No high priority skills identified - Excellent work!\")"
   ]
