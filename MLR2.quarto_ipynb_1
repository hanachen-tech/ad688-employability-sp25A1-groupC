    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| echo: false\n",
        "\n",
        "#| warning: false\n",
        "\n",
        "#| message: false\n",
        "\n",
        "from pyspark.sql import SparkSession\n",
        "\n",
        "from pyspark.sql.functions import col, when, trim, regexp_replace, count as spark_count, lower, explode, split\n",
        "import re\n",
        "\n",
        "from pyspark.ml.feature import StringIndexer, OneHotEncoder, VectorAssembler\n",
        "\n",
        "from pyspark.ml.regression import LinearRegression\n",
        "\n",
        "from pyspark.ml import Pipeline\n",
        "\n",
        "from pyspark.ml.evaluation import RegressionEvaluator\n",
        "\n",
        "from IPython.display import display\n",
        "\n",
        "import pandas as pd\n",
        "\n",
        "import plotly.express as px\n",
        "\n",
        "spark = (\n",
        "    SparkSession.builder\n",
        "    .config(\"spark.driver.host\", \"localhost\")\n",
        "    .config(\"spark.driver.memory\", \"4g\")\n",
        "    .config(\"spark.executor.memory\", \"4g\")\n",
        "    .appName(\"SalaryMLR\")\n",
        "    .getOrCreate()\n",
        ")\n",
        "\n",
        "spark.catalog.clearCache()\n",
        "\n",
        "spark.sparkContext.setLogLevel(\"ERROR\")\n",
        "\n",
        "# Load prepared model-ready dataset from data_cleaning.qmd\n",
        "\n",
        "df_model1_base = spark.read.parquet(\"data/prepared/salary_regression_data.parquet\")\n",
        "\n",
        "skill_count_features_df = spark.read.parquet(\"data/prepared/skill_count_features.parquet\")\n",
        "\n",
        "df_model1_base = df_model1_base.join(\n",
        "\n",
        "    skill_count_features_df,\n",
        "\n",
        "    df_model1_base.id == skill_count_features_df.job_id,\n",
        "\n",
        "    how=\"left\"\n",
        "\n",
        ").drop(\"job_id\")\n",
        "\n",
        "# Add education level from cleaned dataset\n",
        "\n",
        "education_df_model1 = (\n",
        "\n",
        "    spark.read.parquet(\"data/cleaned/lightcast_cleaned.parquet\")\n",
        "\n",
        "    .select(\n",
        "\n",
        "        col(\"ID\").alias(\"id\"),\n",
        "\n",
        "        col(\"EDUCATION_LEVELS_NAME\").alias(\"education_level\")\n",
        "\n",
        "    )\n",
        "\n",
        "    .dropDuplicates([\"id\"])\n",
        "\n",
        ")\n",
        "\n",
        "df_model1_base = (\n",
        "\n",
        "    df_model1_base\n",
        "\n",
        "    .join(education_df_model1, on=\"id\", how=\"left\")\n",
        "\n",
        "    .withColumn(\n",
        "\n",
        "        \"education_level\",\n",
        "\n",
        "        trim(\n",
        "\n",
        "            regexp_replace(\n",
        "\n",
        "                regexp_replace(col(\"education_level\"), r\"[\\n\\r]\", \" \"),\n",
        "\n",
        "                r\"\\s+\",\n",
        "\n",
        "                \" \"\n",
        "\n",
        "            )\n",
        "\n",
        "        )\n",
        "\n",
        "    )\n",
        "\n",
        "    .fillna({\"education_level\": \"Unknown\"})\n",
        "\n",
        ")\n",
        "\n",
        "# Keep only valid salary rows\n",
        "\n",
        "df_salary1 = df_model1_base.filter(\n",
        "\n",
        "    col(\"salary\").isNotNull() &\n",
        "\n",
        "    (col(\"salary\") > 0) &\n",
        "\n",
        "    (col(\"salary\") <= 500000)\n",
        "\n",
        ").cache()\n",
        "\n",
        "\n",
        "# Group job titles using top 30 titles\n",
        "\n",
        "top_titles_model1 = [\n",
        "\n",
        "    r[\"title_clean\"] for r in\n",
        "\n",
        "    df_salary1.groupBy(\"title_clean\")\n",
        "\n",
        "    .agg(spark_count(\"*\").alias(\"cnt\"))\n",
        "\n",
        "    .orderBy(col(\"cnt\").desc())\n",
        "\n",
        "    .limit(30)\n",
        "\n",
        "    .collect()\n",
        "\n",
        "]\n",
        "\n",
        "df_model1 = df_salary1.withColumn(\n",
        "\n",
        "    \"title_grouped\",\n",
        "\n",
        "    when(col(\"title_clean\").isin(top_titles_model1), col(\"title_clean\")).otherwise(\"Other\")\n",
        "\n",
        ")\n",
        "\n",
        "# Skill features prepared in data_cleaning.qmd\n",
        "\n",
        "skill_cols_model1 = [\n",
        "\n",
        "    \"has_python\",\n",
        "\n",
        "    \"has_sql\",\n",
        "\n",
        "    \"has_machine_learning\",\n",
        "\n",
        "    \"has_tableau\",\n",
        "\n",
        "    \"has_power_bi\",\n",
        "\n",
        "    \"has_aws\",\n",
        "\n",
        "    \"has_excel\",\n",
        "\n",
        "    \"has_sap\",\n",
        "\n",
        "    \"common_skill_count\",\n",
        "\n",
        "    \"specialized_skill_count\",\n",
        "\n",
        "    \"software_skill_count\"\n",
        "\n",
        "]\n",
        "\n",
        "# Select Model 1 features\n",
        "\n",
        "df_model1 = (\n",
        "\n",
        "    df_model1\n",
        "\n",
        "    .select(\n",
        "\n",
        "        [\"salary\",\n",
        "\n",
        "         \"state_name\",\n",
        "\n",
        "         \"title_grouped\",\n",
        "\n",
        "         \"remote_type_name\",\n",
        "\n",
        "         \"employment_type_name\",\n",
        "\n",
        "         \"min_years_experience\",\n",
        "\n",
        "         \"education_level\"] + skill_cols_model1\n",
        "\n",
        "    )\n",
        "\n",
        "    .fillna({\n",
        "\n",
        "        \"state_name\": \"Unknown\",\n",
        "\n",
        "        \"title_grouped\": \"Other\",\n",
        "\n",
        "        \"remote_type_name\": \"Unknown\",\n",
        "\n",
        "        \"employment_type_name\": \"Unknown\",\n",
        "\n",
        "        \"min_years_experience\": 0,\n",
        "\n",
        "        \"education_level\": \"Unknown\",\n",
        "\n",
        "        \"has_python\": 0,\n",
        "\n",
        "        \"has_sql\": 0,\n",
        "\n",
        "        \"has_machine_learning\": 0,\n",
        "\n",
        "        \"has_tableau\": 0,\n",
        "\n",
        "        \"has_power_bi\": 0,\n",
        "\n",
        "        \"has_aws\": 0,\n",
        "\n",
        "        \"has_excel\": 0,\n",
        "\n",
        "        \"has_sap\": 0,\n",
        "\n",
        "        \"common_skill_count\": 0,\n",
        "\n",
        "        \"specialized_skill_count\": 0,\n",
        "\n",
        "        \"software_skill_count\": 0\n",
        "\n",
        "    })\n",
        "\n",
        "    .cache()\n",
        "\n",
        ")\n",
        "\n",
        "print(\"Model 1 rows:\", df_model1.count())\n",
        "\n",
        "print(\"Model 1 top 30 grouped titles:\", top_titles_model1[:10], \"...\")\n",
        "\n",
        "# Model 1 categorical encoders\n",
        "\n",
        "title_indexer_model1 = StringIndexer(\n",
        "\n",
        "    inputCol=\"title_grouped\",\n",
        "\n",
        "    outputCol=\"title_idx\",\n",
        "\n",
        "    handleInvalid=\"keep\"\n",
        "\n",
        ")\n",
        "\n",
        "title_encoder_model1 = OneHotEncoder(\n",
        "\n",
        "    inputCol=\"title_idx\",\n",
        "\n",
        "    outputCol=\"title_vec\",\n",
        "\n",
        "    dropLast=False\n",
        "\n",
        ")\n",
        "\n",
        "state_indexer_model1 = StringIndexer(\n",
        "\n",
        "    inputCol=\"state_name\",\n",
        "\n",
        "    outputCol=\"state_idx\",\n",
        "\n",
        "    handleInvalid=\"keep\"\n",
        "\n",
        ")\n",
        "\n",
        "state_encoder_model1 = OneHotEncoder(\n",
        "\n",
        "    inputCol=\"state_idx\",\n",
        "\n",
        "    outputCol=\"state_vec\",\n",
        "\n",
        "    dropLast=False\n",
        "\n",
        ")\n",
        "\n",
        "remote_indexer_model1 = StringIndexer(\n",
        "\n",
        "    inputCol=\"remote_type_name\",\n",
        "\n",
        "    outputCol=\"remote_idx\",\n",
        "\n",
        "    handleInvalid=\"keep\"\n",
        "\n",
        ")\n",
        "\n",
        "remote_encoder_model1 = OneHotEncoder(\n",
        "\n",
        "    inputCol=\"remote_idx\",\n",
        "\n",
        "    outputCol=\"remote_vec\",\n",
        "\n",
        "    dropLast=False\n",
        "\n",
        ")\n",
        "\n",
        "employment_indexer_model1 = StringIndexer(\n",
        "\n",
        "    inputCol=\"employment_type_name\",\n",
        "\n",
        "    outputCol=\"employment_idx\",\n",
        "\n",
        "    handleInvalid=\"keep\"\n",
        "\n",
        ")\n",
        "\n",
        "employment_encoder_model1 = OneHotEncoder(\n",
        "\n",
        "    inputCol=\"employment_idx\",\n",
        "\n",
        "    outputCol=\"employment_vec\",\n",
        "\n",
        "    dropLast=False\n",
        "\n",
        ")\n",
        "\n",
        "education_indexer_model1 = StringIndexer(\n",
        "\n",
        "    inputCol=\"education_level\",\n",
        "\n",
        "    outputCol=\"education_idx\",\n",
        "\n",
        "    handleInvalid=\"keep\"\n",
        "\n",
        ")\n",
        "\n",
        "education_encoder_model1 = OneHotEncoder(\n",
        "\n",
        "    inputCol=\"education_idx\",\n",
        "\n",
        "    outputCol=\"education_vec\",\n",
        "\n",
        "    dropLast=False\n",
        "\n",
        ")\n",
        "\n",
        "assembler_model1 = VectorAssembler(\n",
        "\n",
        "    inputCols=[\n",
        "\n",
        "        \"title_vec\",\n",
        "\n",
        "        \"state_vec\",\n",
        "\n",
        "        \"remote_vec\",\n",
        "\n",
        "        \"employment_vec\",\n",
        "\n",
        "        \"education_vec\",\n",
        "\n",
        "        \"min_years_experience\"\n",
        "\n",
        "    ] + skill_cols_model1,\n",
        "\n",
        "    outputCol=\"features\"\n",
        "\n",
        ")\n",
        "\n",
        "lr_model1_estimator = LinearRegression(\n",
        "\n",
        "    featuresCol=\"features\",\n",
        "\n",
        "    labelCol=\"salary\"\n",
        "\n",
        ")\n",
        "\n",
        "pipeline_model1 = Pipeline(stages=[\n",
        "\n",
        "    title_indexer_model1, title_encoder_model1,\n",
        "\n",
        "    state_indexer_model1, state_encoder_model1,\n",
        "\n",
        "    remote_indexer_model1, remote_encoder_model1,\n",
        "\n",
        "    employment_indexer_model1, employment_encoder_model1,\n",
        "\n",
        "    education_indexer_model1, education_encoder_model1,\n",
        "\n",
        "    assembler_model1, lr_model1_estimator\n",
        "\n",
        "])\n",
        "\n",
        "train_model1, test_model1 = df_model1.randomSplit([0.8, 0.2], seed=42)\n",
        "\n",
        "model1 = pipeline_model1.fit(train_model1)\n",
        "\n",
        "predictions_model1 = model1.transform(test_model1)\n",
        "\n",
        "# Model 1 metrics\n",
        "\n",
        "r2_model1 = RegressionEvaluator(\n",
        "\n",
        "    labelCol=\"salary\",\n",
        "\n",
        "    predictionCol=\"prediction\",\n",
        "\n",
        "    metricName=\"r2\"\n",
        "\n",
        ").evaluate(predictions_model1)\n",
        "\n",
        "rmse_model1 = RegressionEvaluator(\n",
        "\n",
        "    labelCol=\"salary\",\n",
        "\n",
        "    predictionCol=\"prediction\",\n",
        "\n",
        "    metricName=\"rmse\"\n",
        "\n",
        ").evaluate(predictions_model1)\n",
        "\n",
        "mae_model1 = RegressionEvaluator(\n",
        "\n",
        "    labelCol=\"salary\",\n",
        "\n",
        "    predictionCol=\"prediction\",\n",
        "\n",
        "    metricName=\"mae\"\n",
        "\n",
        ").evaluate(predictions_model1)\n",
        "\n",
        "lr_model1 = model1.stages[-1]\n",
        "\n",
        "n_model1 = predictions_model1.count()\n",
        "\n",
        "p_model1 = len(lr_model1.coefficients)\n",
        "\n",
        "adjusted_r2_model1 = (\n",
        "\n",
        "    1 - ((1 - r2_model1) * (n_model1 - 1) / (n_model1 - p_model1 - 1))\n",
        "\n",
        "    if n_model1 > p_model1 + 1\n",
        "\n",
        "    else None\n",
        "\n",
        ")\n",
        "\n",
        "metrics_df_model1 = pd.DataFrame({\n",
        "\n",
        "    \"Metric\": [\"R²\", \"Adjusted R²\", \"RMSE\", \"MAE\"],\n",
        "\n",
        "    \"Value\": [\n",
        "\n",
        "        round(r2_model1, 4),\n",
        "\n",
        "        round(adjusted_r2_model1, 4) if adjusted_r2_model1 is not None else None,\n",
        "\n",
        "        round(rmse_model1, 2),\n",
        "\n",
        "        round(mae_model1, 2)\n",
        "\n",
        "    ]\n",
        "\n",
        "})\n",
        "\n",
        "display(metrics_df_model1)\n",
        "\n",
        "# Salary benchmark for interpreting RMSE/MAE scale\n",
        "salary_stats_model1 = df_salary1.selectExpr(\n",
        "    \"min(salary) as min_salary\",\n",
        "    \"percentile_approx(salary, 0.5) as median_salary\",\n",
        "    \"max(salary) as max_salary\"\n",
        ").collect()[0]\n",
        "\n",
        "salary_benchmark_df = pd.DataFrame({\n",
        "    \"Statistic\": [\"Min Salary\", \"Median Salary\", \"Max Salary\"],\n",
        "    \"Value\": [\n",
        "        round(salary_stats_model1[\"min_salary\"], 2),\n",
        "        round(salary_stats_model1[\"median_salary\"], 2),\n",
        "        round(salary_stats_model1[\"max_salary\"], 2)\n",
        "    ]\n",
        "})\n",
        "\n",
        "print(\"\\n=== Salary Distribution Benchmark (for interpreting RMSE/MAE) ===\")\n",
        "display(salary_benchmark_df)\n",
        "\n",
        "rmse_pct_of_median_model1 = rmse_model1 / salary_stats_model1[\"median_salary\"] * 100\n",
        "mae_pct_of_median_model1 = mae_model1 / salary_stats_model1[\"median_salary\"] * 100\n",
        "\n",
        "print(f\"\\nModel 1 RMSE is {rmse_pct_of_median_model1:.1f}% of median salary\")\n",
        "print(f\"Model 1 MAE is {mae_pct_of_median_model1:.1f}% of median salary\")"
      ],
      "id": "6914d6bf",
      "execution_count": null,
      "outputs": []
    },
