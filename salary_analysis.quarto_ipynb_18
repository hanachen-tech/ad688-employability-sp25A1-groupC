    "remote_salary = spark.sql(\"\"\"\n",
    "SELECT\n",
    "    COALESCE(remote_type_name,'Unknown') AS remote_type,\n",
    "    CAST(salary AS DOUBLE) AS salary\n",
    "FROM job_postings\n",
    "WHERE\n",
    "    salary IS NOT NULL\n",
    "    AND CAST(salary AS DOUBLE) > 0\n",
    "    AND COALESCE(remote_type_name,'Unknown') != 'Unknown'\n",
    "\"\"\")\n",
    "\n",
    "remote_salary_pd = remote_salary.toPandas()\n",
    "remote_salary_pd[\"remote_type\"] = remote_salary_pd[\"remote_type\"].astype(str)\n",
    "remote_salary_pd = remote_salary_pd[\n",
    "    (~remote_salary_pd[\"remote_type\"].isna()) & \n",
    "    (~remote_salary_pd[\"remote_type\"].isin([\"None\", \"Unknown\", \"nan\", \"null\", \"\", \"[None]\"]))\n",
    "]\n",
    "\n",
    "print(remote_salary_pd['remote_type'].unique())\n",
    "\n",
    "fig_remote = px.box(\n",
    "    remote_salary_pd,\n",
    "    x=\"remote_type\",\n",
    "    y=\"salary\",\n",
    "    color=\"remote_type\",\n",
    "    title=\"Salary by Remote Work Arrangement\"\n",
    ")\n",
    "\n",
    "fig_remote.update_layout(\n",
    "    template=\"plotly_white\",\n",
    "    showlegend=False,\n",
    "    yaxis_title=\"Salary ($)\",\n",
    "    xaxis_title=\"\"\n",
    ")\n",
    "\n",
    "#fig_remote.show()"
   ]
