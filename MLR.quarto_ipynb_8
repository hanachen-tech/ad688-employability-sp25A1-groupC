    "        \"employment_vec\",\n",
    "        \"education_vec\",\n",
    "        \"min_years_experience\",\n",
    "        \"is_ai_related\"\n",
    "    ] + skill_cols_model2,\n",
    "    outputCol=\"features\"\n",
    ")\n",
    "\n",
    "lr_model2_estimator = LinearRegression(\n",
