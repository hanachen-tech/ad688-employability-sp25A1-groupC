    "\n",
    "    dropLast=False\n",
    "\n",
    ")\n",
    "\n",
    "assembler_model2 = VectorAssembler(\n",
    "    inputCols=[\n",
    "        \"title_vec\",\n",
    "        \"occupation_group_vec\",\n",
    "        \"specialized_occupation_vec\",\n",
    "        \"state_vec\",\n",
