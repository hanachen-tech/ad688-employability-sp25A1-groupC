    "\n",
    "# Load prepared model-ready dataset from data_cleaning.qmd\n",
    "\n",
    "df_model2_base = spark.read.parquet(\"data/prepared/salary_regression_data.parquet\")\n",
    "\n",
    "df_model2_base = df_model2_base.join(\n",
    "\n",
    "    skill_count_features_df,\n",
