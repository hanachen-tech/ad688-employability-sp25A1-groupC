    "\n",
    "        predictionCol=\"prediction\",\n",
    "\n",
    "        metricName=\"r2\"\n",
    "\n",
    "    ).evaluate(temp_predictions)\n",
    "\n",
    "    temp_rmse = RegressionEvaluator(\n",
    "\n",
    "        labelCol=\"salary\",\n",
    "\n",
    "        predictionCol=\"prediction\",\n",
    "\n",
    "        metricName=\"rmse\"\n",
    "\n",
    "    ).evaluate(temp_predictions)\n",
    "\n",
    "    temp_mae = RegressionEvaluator(\n",
    "\n",
    "        labelCol=\"salary\",\n",
    "\n",
    "        predictionCol=\"prediction\",\n",
    "\n",
    "        metricName=\"mae\"\n",
    "\n",
    "    ).evaluate(temp_predictions)\n",
