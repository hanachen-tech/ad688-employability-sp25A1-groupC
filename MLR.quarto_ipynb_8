    "        col(\"EDUCATION_LEVELS_NAME\").alias(\"education_level\")\n",
    "\n",
    "    )\n",
    "\n",
    "    .dropDuplicates([\"id\"])\n",
    "\n",
    ")\n",
    "\n",
    "df_model2_base = (\n",
    "\n",
    "    df_model2_base\n",
    "\n",
    "    .join(education_df_model2, on=\"id\", how=\"left\")\n",
    "\n",
    "    .withColumn(\n",
    "\n",
    "        \"education_level\",\n",
    "\n",
    "        trim(\n",
    "\n",
    "            regexp_replace(\n",
    "\n",
    "                regexp_replace(col(\"education_level\"), r\"[\\n\\r]\", \" \"),\n",
