    "    <label>Job Title Group<br><select id=\"sw-title\" style=\"width:100%; padding:6px;\"></select></label>\n",
    "    <label>Occupation Group<br><select id=\"sw-occupation-group\" style=\"width:100%; padding:6px;\"></select></label>\n",
    "    <label>Specialized Occupation<br><select id=\"sw-specialized-occupation\" style=\"width:100%; padding:6px;\"></select></label>\n",
    "    <label>Remote Type<br><select id=\"sw-remote\" style=\"width:100%; padding:6px;\"></select></label>\n",
    "    <label>Employment Type<br><select id=\"sw-employment\" style=\"width:100%; padding:6px;\"></select></label>\n",
    "    <label>Education Level<br><select id=\"sw-education\" style=\"width:100%; padding:6px;\"></select></label>\n",
    "    <label>Minimum Years Experience<br><input id=\"sw-years\" type=\"number\" value=\"0\" min=\"0\" step=\"1\" style=\"width:100%; padding:6px;\"></label>\n",
    "  </div>\n",
    "\n",
    "  <h4>Skills Mentioned in Posting</h4>\n",
    "  <div id=\"sw-skills\" style=\"display:grid; grid-template-columns:1fr 1fr; gap:8px;\"></div>\n",
    "\n",
    "  <div style=\"margin-top:18px; padding:14px; background:#f8f9fa; border-radius:10px;\">\n",
    "    <div style=\"font-size:13px; color:#666;\">Predicted Salary</div>\n",
    "    <div id=\"sw-prediction\" style=\"font-size:34px; font-weight:bold;\">$0</div>\n",
    "    <div id=\"sw-factors\" style=\"margin-top:12px; font-size:14px;\"></div>\n",
    "  </div>\n",
    "</div>\n",
    "\n",
    "<label>AI Related Job<br>\n",
    "  <select id=\"sw-ai\" style=\"width:100%; padding:6px;\">\n",
    "    <option value=\"0\">No</option>\n",
    "    <option value=\"1\">Yes</option>\n",
    "  </select>\n",
    "</label>\n",
    "\n",
    "<script>\n",
    "const salaryModel = {payload_json};\n",
    "\n",
    "function addOptions(selectId, values) {{\n",
    "  const el = document.getElementById(selectId);\n",
    "  values.forEach(v => {{\n",
    "    const opt = document.createElement(\"option\");\n",
    "    opt.value = v;\n",
    "    opt.textContent = v;\n",
    "    el.appendChild(opt);\n",
    "  }});\n",
    "}}\n",
    "\n",
    "function prettySkill(s) {{\n",
    "  const names = {{\n",
    "    \"has_python\": \"Python\",\n",
    "    \"has_sql\": \"SQL\",\n",
    "    \"has_machine_learning\": \"Machine Learning\",\n",
    "    \"has_tableau\": \"Tableau\",\n",
    "    \"has_power_bi\": \"Power BI\",\n",
    "    \"has_aws\": \"AWS\",\n",
    "    \"has_excel\": \"Excel\",\n",
    "    \"has_sap\": \"SAP\"\n",
    "  }};\n",
    "  return names[s] || s.replace(\"has_\", \"\").replaceAll(\"_\", \" \");\n",
    "}}\n",
    "\n",
    "function money(x) {{\n",
    "  return \"$\" + Math.round(x).toLocaleString();\n",
    "}}\n",
    "\n",
    "function updatePrediction() {{\n",
    "  let pred = salaryModel.intercept;\n",
    "  let factors = [];\n",
    "\n",
    "  const state = document.getElementById(\"sw-state\").value;\n",
    "  const title = document.getElementById(\"sw-title\").value;\n",
    "  const occupationGroup = document.getElementById(\"sw-occupation-group\").value;\n",
    "  const specializedOccupation = document.getElementById(\"sw-specialized-occupation\").value;\n",
    "  const remote = document.getElementById(\"sw-remote\").value;\n",
    "  const education = document.getElementById(\"sw-education\").value;\n",
    "  const years = parseFloat(document.getElementById(\"sw-years\").value || \"0\");\n",
    "  const employment = document.getElementById(\"sw-employment\").value;\n",
    "  const isAI = parseFloat(document.getElementById(\"sw-ai\").value || \"0\");\n",
    "\n",
    "  const featureKeys = [\n",
    "    \"State: \" + state,\n",
    "    \"Title: \" + title,\n",
    "    \"Occupation Group: \" + occupationGroup,\n",
    "    \"Specialized Occupation: \" + specializedOccupation,\n",
    "    \"Remote: \" + remote,\n",
    "    \"Education: \" + education,\n",
    "    \"Employment: \" + employment,\n",
    "    \"Is AI Related: \" + isAI\n",
    "  ];\n",
    "\n",
    "  featureKeys.forEach(k => {{\n",
    "    const c = salaryModel.coef[k] || 0;\n",
    "    pred += c;\n",
    "    if (Math.abs(c) > 1) factors.push([k, c]);\n",
    "  }});\n",
    "\n",
    "  const yearCoef = salaryModel.coef[\"Minimum Years Experience\"] || 0;\n",
    "  pred += yearCoef * years;\n",
    "  if (Math.abs(yearCoef * years) > 1) factors.push([\"Minimum Years Experience\", yearCoef * years]);\n",
    "  const aiCoef = salaryModel.coef[\"Is AI Related\"] || 0;\n",
    "pred += aiCoef * isAI;\n",
    "if (Math.abs(aiCoef * isAI) > 1) factors.push([\"Is AI Related\", aiCoef * isAI]);\n",
    "\n",
    "  salaryModel.skills.forEach(s => {{\n",
    "    const box = document.getElementById(\"sw-\" + s);\n",
    "    if (box && box.checked) {{\n",
    "      const key = \"Skill: \" + prettySkill(s);\n",
    "      const c = salaryModel.coef[key] || 0;\n",
    "      pred += c;\n",
    "      if (Math.abs(c) > 1) factors.push([key, c]);\n",
    "    }}\n",
    "  }});\n",
    "\n",
    "  document.getElementById(\"sw-prediction\").textContent = money(pred);\n",
    "\n",
    "  factors.sort((a,b) => Math.abs(b[1]) - Math.abs(a[1]));\n",
    "  const topFactors = factors.slice(0,5).map(([k,c]) => {{\n",
    "    const arrow = c >= 0 ? \"↑\" : \"↓\";\n",
    "    const color = c >= 0 ? \"#2ca02c\" : \"#d62728\";\n",
    "    return `<div style=\"color:${{color}};\">${{arrow}} ${{k}} (${{money(c)}})</div>`;\n",
    "  }}).join(\"\");\n",
    "\n",
    "  document.getElementById(\"sw-factors\").innerHTML =\n",
    "    \"<strong>Top factors in this prediction</strong>\" + topFactors;\n",
    "}}\n",
    "\n",
    "addOptions(\"sw-state\", salaryModel.states);\n",
    "addOptions(\"sw-title\", salaryModel.titles);\n",
    "addOptions(\"sw-occupation-group\", salaryModel.occupation_groups);\n",
    "addOptions(\"sw-specialized-occupation\", salaryModel.specialized_occupations);\n",
    "addOptions(\"sw-remote\", salaryModel.remotes);\n",
    "addOptions(\"sw-education\", salaryModel.educations);\n",
    "addOptions(\"sw-employment\", salaryModel.employments);\n",
    "addOptions(\"sw-ai\", [\"0\", \"1\"]);\n",
    "\n",
    "const skillsDiv = document.getElementById(\"sw-skills\");\n",
    "salaryModel.skills.forEach(s => {{\n",
    "  const label = document.createElement(\"label\");\n",
    "  label.innerHTML = `<input type=\"checkbox\" id=\"sw-${{s}}\"> ${{prettySkill(s)}}`;\n",
    "  skillsDiv.appendChild(label);\n",
    "}});\n",
    "\n",
    "document.querySelectorAll(\"#salary-widget select, #salary-widget input\").forEach(el => {{\n",
    "  el.addEventListener(\"change\", updatePrediction);\n",
    "  el.addEventListener(\"input\", updatePrediction);\n",
    "}});\n",
    "\n",
    "updatePrediction();\n",
    "</script>\n",
    "\"\"\"\n",
    "\n",
    "display(HTML(html))"
   ]
  }
 ],
