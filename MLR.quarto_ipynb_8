    "    outputCol=\"state_idx\",\n",
    "\n",
    "    handleInvalid=\"keep\"\n",
    "\n",
    ")\n",
    "\n",
    "state_encoder_model2 = OneHotEncoder(\n",
    "\n",
    "    inputCol=\"state_idx\",\n",
    "\n",
    "    outputCol=\"state_vec\",\n",
    "\n",
    "    dropLast=False\n",
    "\n",
    ")\n",
    "\n",
    "remote_indexer_model2 = StringIndexer(\n",
    "\n",
    "    inputCol=\"remote_type_name\",\n",
    "\n",
    "    outputCol=\"remote_idx\",\n",
    "\n",
    "    handleInvalid=\"keep\"\n",
    "\n",
    ")\n",
    "\n",
    "remote_encoder_model2 = OneHotEncoder(\n",
    "\n",
    "    inputCol=\"remote_idx\",\n",
    "\n",
    "    outputCol=\"remote_vec\",\n",
    "\n",
    "    dropLast=False\n",
    "\n",
    ")\n",
    "employment_indexer_model2 = StringIndexer(\n",
