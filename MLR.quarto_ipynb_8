    "\n",
    "    education_indexer_model1, education_encoder_model1\n",
    "\n",
    "]\n",
    "\n",
    "def evaluate_without_group_model1(group_to_remove):\n",
    "\n",
    "    selected_inputs = []\n",
    "\n",
    "    for group_name, cols in base_feature_groups_model1.items():\n",
    "\n",
    "        if group_name != group_to_remove:\n",
    "\n",
    "            selected_inputs.extend(cols)\n",
    "\n",
    "    temp_assembler = VectorAssembler(\n",
    "\n",
    "        inputCols=selected_inputs,\n",
    "\n",
    "        outputCol=\"features\"\n",
    "\n",
    "    )\n",
    "\n",
    "    temp_lr = LinearRegression(\n",
    "\n",
    "        featuresCol=\"features\",\n",
    "\n",
    "        labelCol=\"salary\"\n",
    "\n",
    "    )\n",
    "\n",
    "    temp_pipeline = Pipeline(\n",
    "\n",
    "        stages=base_transform_stages_model1 + [temp_assembler, temp_lr]\n",
    "\n",
    "    )\n",
    "\n",
    "    temp_model = temp_pipeline.fit(train_model1)\n",
    "\n",
    "    temp_predictions = temp_model.transform(test_model1)\n",
    "\n",
    "    temp_r2 = RegressionEvaluator(\n",
