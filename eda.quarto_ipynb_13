    "#| echo: fenced\n",
    "#| code-fold: true\n",
    "#| code-summary: Show code\n",
    "#| warning: false\n",
    "\n",
    "education_salary = spark.sql(\"\"\"\n",
    "SELECT\n",
    "    CASE\n",
    "        WHEN LOWER(COALESCE(e.education_level, 'Unknown')) LIKE '%ph.d%' THEN 'PhD / Professional'\n",
    "        WHEN LOWER(COALESCE(e.education_level, 'Unknown')) LIKE '%professional degree%' THEN 'PhD / Professional'\n",
    "        WHEN LOWER(COALESCE(e.education_level, 'Unknown')) LIKE '%master%' THEN 'Master'\n",
    "        WHEN LOWER(COALESCE(e.education_level, 'Unknown')) LIKE '%bachelor%' THEN 'Bachelor'\n",
    "        WHEN LOWER(COALESCE(e.education_level, 'Unknown')) LIKE '%associate%' THEN 'Associate'\n",
    "        WHEN LOWER(COALESCE(e.education_level, 'Unknown')) LIKE '%high school%' THEN 'High School / GED'\n",
    "        ELSE 'Unknown'\n",
    "    END AS education_level_clean,\n",
    "    j.salary\n",
    "FROM job_postings j\n",
    "LEFT JOIN education_levels e\n",
    "    ON j.id = e.id\n",
    "WHERE j.salary IS NOT NULL\n",
    "  AND j.salary > 0\n",
    "  AND j.salary <= 500000\n",
    "\"\"\").toPandas()\n",
    "\n",
    "education_order = [\n",
    "    \"High School / GED\",\n",
    "    \"Associate\",\n",
    "    \"Bachelor\",\n",
    "    \"Master\",\n",
    "    \"PhD / Professional\",\n",
    "    \"Unknown\"\n",
    "]\n",
    "\n",
    "fig_education_salary = px.box(\n",
    "    education_salary,\n",
    "    x=\"education_level_clean\",\n",
    "    y=\"salary\",\n",
    "    color=\"education_level_clean\",\n",
    "    category_orders={\"education_level_clean\": education_order},\n",
    "    title=\"Salary Distribution by Education Level\",\n",
    "    labels={\n",
    "        \"education_level_clean\": \"Education Level\",\n",
    "        \"salary\": \"Salary ($)\"\n",
    "    },\n",
    "    color_discrete_sequence=px.colors.qualitative.Set3\n",
    ")\n",
    "\n",
    "fig_education_salary.update_layout(\n",
    "    template=\"plotly_white\",\n",
    "    height=480,\n",
    "    margin=dict(l=60, r=40, t=70, b=90),\n",
    "    title=dict(x=0.02, xanchor=\"left\"),\n",
    "    showlegend=False,\n",
    "    xaxis_tickangle=-25,\n",
    "    yaxis=dict(tickprefix=\"$\", separatethousands=True)\n",
    ")\n",
    "\n",
    "fig_education_salary.show()"
   ]
