    "\n",
    "top_skills_plot = top_skills.copy()\n",
    "\n",
    "# Sort descending by job count\n",
    "top_skills_plot = top_skills_plot.sort_values(\"job_count\", ascending=False)\n",
    "\n",
    "# Plotly horizontal bars display category order bottom-to-top,\n",
    "# so reverse the order to show largest skill at the top.\n",
