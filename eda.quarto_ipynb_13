    "#| echo: false\n",
    "#| warning: false\n",
    "\n",
    "possible_ai_skills = spark.sql(\"\"\"\n",
    "SELECT\n",
    "    skill_name,\n",
    "    skill_type,\n",
    "    COUNT(DISTINCT job_id) AS job_count\n",
    "FROM job_skill_matches\n",
    "WHERE\n",
    "    LOWER(skill_name) LIKE '%machine%'\n",
    "    OR LOWER(skill_name) LIKE '%learning%'\n",
    "    OR LOWER(skill_name) LIKE '%artificial%'\n",
    "    OR LOWER(skill_name) LIKE '%intelligence%'\n",
    "    OR LOWER(skill_name) LIKE '%deep%'\n",
    "    OR LOWER(skill_name) LIKE '%neural%'\n",
    "    OR LOWER(skill_name) LIKE '%natural language%'\n",
    "    OR LOWER(skill_name) LIKE '%nlp%'\n",
    "    OR LOWER(skill_name) LIKE '%vision%'\n",
    "    OR LOWER(skill_name) LIKE '%generative%'\n",
    "    OR LOWER(skill_name) LIKE '%language model%'\n",
    "    OR LOWER(skill_name) LIKE '%llm%'\n",
    "    OR LOWER(skill_name) LIKE '%predictive%'\n",
    "    OR LOWER(skill_name) LIKE '%model%'\n",
    "    OR LOWER(skill_name) LIKE '%algorithm%'\n",
    "    OR LOWER(skill_name) LIKE '%data science%'\n",
    "GROUP BY\n",
    "    skill_name,\n",
    "    skill_type\n",
    "ORDER BY\n",
    "    job_count DESC\n",
    "LIMIT 100\n",
    "\"\"\").toPandas()\n",
    "\n",
    "display(style_table(possible_ai_skills, {\n",
    "    \"job_count\": \"{:,.0f}\"\n",
    "}))"
   ]
