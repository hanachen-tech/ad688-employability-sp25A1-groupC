    "#| echo: fenced\n",
    "#| code-fold: true\n",
    "#| code-summary: Show code\n",
    "#| warning: false\n",
    "\n",
    "occupation_salary = spark.sql(\"\"\"\n",
    "WITH top_occ AS (\n",
    "    SELECT\n",
    "        o.specialized_occupation_name,\n",
    "        COUNT(*) AS job_count\n",
    "    FROM job_postings j\n",
    "    LEFT JOIN occupations o\n",
    "        ON j.occupation_id = o.occupation_id\n",
    "    WHERE j.salary IS NOT NULL\n",
    "      AND j.salary > 0\n",
    "      AND j.salary <= 500000\n",
    "      AND o.specialized_occupation_name IS NOT NULL\n",
    "    GROUP BY o.specialized_occupation_name\n",
    "    ORDER BY job_count DESC\n",
    "    LIMIT 8\n",
    ")\n",
    "SELECT\n",
    "    o.specialized_occupation_name,\n",
    "    j.salary\n",
    "FROM job_postings j\n",
    "LEFT JOIN occupations o\n",
    "    ON j.occupation_id = o.occupation_id\n",
    "INNER JOIN top_occ t\n",
    "    ON o.specialized_occupation_name = t.specialized_occupation_name\n",
    "WHERE j.salary IS NOT NULL\n",
    "  AND j.salary > 0\n",
    "  AND j.salary <= 500000\n",
    "\"\"\").toPandas()\n",
    "\n",
    "occupation_salary_plot = occupation_salary.copy()\n",
    "\n",
    "fig_occupation_salary = px.box(\n",
    "    occupation_salary_plot,\n",
    "    x=\"salary\",\n",
    "    y=\"specialized_occupation_name\",\n",
    "    color=\"specialized_occupation_name\",\n",
    "    orientation=\"h\",\n",
    "    title=\"Salary Distribution by Top Occupation Categories\",\n",
    "    labels={\n",
    "        \"specialized_occupation_name\": \"Occupation Category\",\n",
    "        \"salary\": \"Salary ($)\"\n",
    "    },\n",
    "    color_discrete_sequence=px.colors.qualitative.Set3\n",
    ")\n",
    "\n",
    "fig_occupation_salary.update_layout(\n",
    "    template=\"plotly_white\",\n",
    "    height=620,\n",
    "    margin=dict(l=270, r=60, t=70, b=60),\n",
    "    title=dict(x=0.02, xanchor=\"left\"),\n",
    "    showlegend=False,\n",
    "    font=dict(size=12),\n",
    "    xaxis=dict(\n",
    "        tickprefix=\"$\",\n",
    "        separatethousands=True,\n",
    "        gridcolor=\"rgba(0,0,0,0.08)\"\n",
    "    ),\n",
    "    yaxis=dict(\n",
    "        title=\"\",\n",
    "        automargin=True\n",
    "    )\n",
    ")\n",
    "\n",
    "fig_occupation_salary.show()"
