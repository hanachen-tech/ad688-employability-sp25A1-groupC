    "#| echo: false\n",
    "#| warning: false\n",
    "\n",
    "top_industries = spark.sql(\"\"\"\n",
    "SELECT\n",
    "    i.naics_2022_6_name AS industry,\n",
    "    COUNT(*) AS job_count\n",
    "FROM job_postings j\n",
    "LEFT JOIN industries i\n",
    "    ON j.industry_id = i.industry_id\n",
    "WHERE i.naics_2022_6_name IS NOT NULL\n",
    "GROUP BY i.naics_2022_6_name\n",
    "ORDER BY job_count DESC\n",
    "LIMIT 10\n",
    "\"\"\").toPandas()\n",
    "\n",
    "display(style_table(top_industries, {\n",
    "    \"job_count\": \"{:,.0f}\"\n",
    "}))"
