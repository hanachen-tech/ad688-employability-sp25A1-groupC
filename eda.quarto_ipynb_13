    "#| echo: false\n",
    "#| warning: false\n",
    "\n",
    "top_states = spark.sql(\"\"\"\n",
    "SELECT\n",
    "    l.state_name AS state_name,\n",
    "    COUNT(*) AS job_count\n",
    "FROM job_postings j\n",
    "LEFT JOIN locations l\n",
    "    ON j.location_id = l.location_id\n",
    "WHERE l.state_name IS NOT NULL\n",
    "GROUP BY l.state_name\n",
    "ORDER BY job_count DESC\n",
    "LIMIT 10\n",
    "\"\"\").toPandas()\n",
    "\n",
    "display(style_table(top_states, {\n",
    "    \"job_count\": \"{:,.0f}\"\n",
    "}))"
