   "source": [
    "#| echo: false\n",
    "#| warning: false\n",
    "\n",
    "salary_availability = spark.sql(\"\"\"\n",
    "SELECT\n",
    "    CASE\n",
    "        WHEN salary IS NOT NULL AND salary > 0\n",
    "        THEN 'Salary Available'\n",
    "        ELSE 'Salary Missing'\n",
    "    END AS salary_status,\n",
    "    COUNT(*) AS job_count,\n",
    "    ROUND(COUNT(*) / (SELECT COUNT(*) FROM job_postings) * 100, 2) AS job_share\n",
    "FROM job_postings\n",
    "GROUP BY\n",
    "    CASE\n",
    "        WHEN salary IS NOT NULL AND salary > 0\n",
    "        THEN 'Salary Available'\n",
    "        ELSE 'Salary Missing'\n",
    "    END\n",
    "ORDER BY job_count DESC\n",
    "\"\"\").toPandas()\n",
    "\n",
    "display(style_table(salary_availability, {\n",
    "    \"job_count\": \"{:,.0f}\",\n",
    "    \"job_share\": \"{:.2f}%\"\n",
    "}))"
