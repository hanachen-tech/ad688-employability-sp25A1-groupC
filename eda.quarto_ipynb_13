    "#| echo: fenced\n",
    "#| code-fold: true\n",
    "#| code-summary: Show code\n",
    "#| warning: false\n",
    "\n",
    "remote_summary = spark.sql(\"\"\"\n",
    "SELECT\n",
    "    COALESCE(remote_type_name, 'Unknown') AS remote_type,\n",
    "    COUNT(*) AS job_count\n",
    "FROM job_postings\n",
    "GROUP BY COALESCE(remote_type_name, 'Unknown')\n",
    "ORDER BY job_count DESC\n",
    "\"\"\").toPandas()\n",
    "\n",
    "remote_summary[\"job_share\"] = (\n",
    "    remote_summary[\"job_count\"] / remote_summary[\"job_count\"].sum()\n",
    ")\n",
    "\n",
    "display(style_table(remote_summary, {\n",
    "    \"job_count\": \"{:,.0f}\",\n",
    "    \"job_share\": \"{:.1%}\"\n",
    "}))\n",
    "\n",
    "fig_remote = px.bar(\n",
    "    remote_summary,\n",
    "    x=\"remote_type\",\n",
    "    y=\"job_count\",\n",
    "    text=\"job_count\",\n",
    "    color=\"remote_type\",\n",
    "    color_discrete_sequence=px.colors.qualitative.Set2,\n",
    "    title=\"Remote Type Distribution\",\n",
    "    labels={\n",
    "        \"remote_type\": \"Remote Work Type\",\n",
    "        \"job_count\": \"Number of Job Postings\"\n",
    "    }\n",
    ")\n",
    "\n",
    "fig_remote.update_traces(\n",
    "    texttemplate=\"%{text:,.0f}\",\n",
    "    textposition=\"outside\",\n",
    "    marker_line_width=0\n",
    ")\n",
    "\n",
    "fig_remote.update_layout(\n",
    "    template=\"plotly_white\",\n",
    "    height=420,\n",
    "    margin=dict(l=60, r=40, t=70, b=60),\n",
    "    title=dict(x=0.02, xanchor=\"left\"),\n",
    "    showlegend=False,\n",
    "    font=dict(size=12),\n",
    "    yaxis=dict(gridcolor=\"rgba(0,0,0,0.08)\")\n",
    ")\n",
    "\n",
    "fig_remote.show()"
   ]
  },
