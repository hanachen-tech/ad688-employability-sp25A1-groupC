   "source": [
    "top_skills = spark.sql(\"\"\"\n",
    "SELECT\n",
    "    skill_name,\n",
    "    skill_type,\n",
    "    COUNT(DISTINCT job_id) AS job_count\n",
    "FROM job_skill_matches\n",
    "GROUP BY\n",
    "    skill_name,\n",
    "    skill_type\n",
    "ORDER BY\n",
    "    job_count DESC\n",
    "LIMIT 100\n",
    "\"\"\")\n",
    "\n",
    "top_skills_pd = top_skills.toPandas()\n",
    "\n",
    "style_table(top_skills_pd, {\n",
    "    \"job_count\": \"{:,.0f}\"\n",
