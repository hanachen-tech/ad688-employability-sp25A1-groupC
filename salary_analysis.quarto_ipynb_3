   "source": [
    "career_title_preview = spark.sql(\"\"\"\n",
    "SELECT\n",
    "    o.specialized_occupation_name,\n",
    "    COUNT(j.id) AS job_count,\n",
    "    COUNT(DISTINCT j.title_clean) AS unique_job_titles,\n",
    "    CONCAT_WS(', ', SLICE(COLLECT_SET(j.title_clean), 1, 10)) AS sample_titles\n",
    "FROM job_postings j\n",
    "LEFT JOIN occupations o\n",
    "    ON j.occupation_id = o.occupation_id\n",
    "WHERE\n",
    "    o.specialized_occupation_name IS NOT NULL\n",
