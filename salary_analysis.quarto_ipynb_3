    "from pyspark.sql.functions import split, explode, trim, lit, monotonically_increasing_id, regexp_replace, col\n",
    "\n",
    "def create_skill_matches(column_name, skill_type):\n",
    "    return df_clean.select(\n",
    "        col(\"ID\").alias(\"job_id\"),\n",
    "        explode(split(col(column_name), \",\")).alias(\"skill_name\")\n",
    "    ).withColumn(\n",
    "        \"skill_name\",\n",
    "        regexp_replace(col(\"skill_name\"), r'[\\[\\]\"]', \"\")\n",
    "    ).withColumn(\n",
    "        \"skill_name\",\n",
    "        trim(col(\"skill_name\"))\n",
    "    ).withColumn(\n",
    "        \"skill_type\",\n",
    "        lit(skill_type)\n",
    "    ).filter(\n",
    "        col(\"skill_name\").isNotNull() & (col(\"skill_name\") != \"\")\n",
    "    )\n",
    "\n",
    "specialized_skill_matches = create_skill_matches(\n",
    "    \"SPECIALIZED_SKILLS_NAME\",\n",
    "    \"specialized\"\n",
    ")\n",
    "\n",
    "common_skill_matches = create_skill_matches(\n",
    "    \"COMMON_SKILLS_NAME\",\n",
    "    \"common\"\n",
    ")\n",
    "\n",
    "software_skill_matches = create_skill_matches(\n",
    "    \"SOFTWARE_SKILLS_NAME\",\n",
    "    \"software\"\n",
    ")\n",
    "\n",
    "certification_matches = create_skill_matches(\n",
    "    \"CERTIFICATIONS_NAME\",\n",
    "    \"certification\"\n",
    ")\n",
    "\n",
    "job_skill_matches_raw = specialized_skill_matches.unionByName(\n",
    "    common_skill_matches\n",
    ").unionByName(\n",
    "    software_skill_matches\n",
    ").unionByName(\n",
    "    certification_matches\n",
    ").dropDuplicates([\"job_id\", \"skill_name\", \"skill_type\"])\n",
    "\n",
    "skills_df = job_skill_matches_raw.select(\n",
    "    \"skill_name\",\n",
    "    \"skill_type\"\n",
    ").dropDuplicates()\n",
    "\n",
    "skills_df = skills_df.withColumn(\n",
    "    \"skill_id\",\n",
    "    monotonically_increasing_id()\n",
    ")\n",
    "\n",
    "skills_df = skills_df.select(\n",
    "    \"skill_id\",\n",
    "    \"skill_name\",\n",
    "    \"skill_type\"\n",
    ")\n",
    "\n",
    "skills_df.createOrReplaceTempView(\"skills\")\n",
    "\n",
    "job_skill_matches_df = job_skill_matches_raw.join(\n",
    "    skills_df,\n",
    "    on=[\"skill_name\", \"skill_type\"],\n",
    "    how=\"left\"\n",
    ").select(\n",
    "    \"job_id\",\n",
    "    \"skill_id\",\n",
    "    \"skill_name\",\n",
    "    \"skill_type\"\n",
    ")\n",
    "\n",
    "job_skill_matches_df.createOrReplaceTempView(\"job_skill_matches\")"
   ]
