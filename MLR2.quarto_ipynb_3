    "\n",
    "importances_model3 = rf_model3.featureImportances.toArray()\n",
    "\n",
    "# Same label-extraction pattern as Model 2's coefficient table, just pointed at\n",
    "# model3's fitted StringIndexer stages instead of model2's.\n",
    "title_labels_model3 = list(model3.stages[0].labels) + [\"title_unseen\"]\n",
    "occupation_group_labels_model3 = list(model3.stages[2].labels) + [\"occupation_group_unseen\"]\n",
    "specialized_occupation_labels_model3 = list(model3.stages[4].labels) + [\"specialized_occupation_unseen\"]\n",
    "state_labels_model3 = list(model3.stages[6].labels) + [\"state_unseen\"]\n",
    "remote_labels_model3 = list(model3.stages[8].labels) + [\"remote_unseen\"]\n",
    "employment_labels_model3 = list(model3.stages[10].labels) + [\"employment_unseen\"]\n",
    "education_labels_model3 = list(model3.stages[12].labels) + [\"education_unseen\"]\n",
    "\n",
    "feature_names_model3 = (\n",
    "    [\"Title: \" + x for x in title_labels_model3] +\n",
    "    [\"Occupation Group: \" + x for x in occupation_group_labels_model3] +\n",
    "    [\"Specialized Occupation: \" + x for x in specialized_occupation_labels_model3] +\n",
    "    [\"State: \" + x for x in state_labels_model3] +\n",
    "    [\"Remote: \" + x for x in remote_labels_model3] +\n",
    "    [\"Employment: \" + x for x in employment_labels_model3] +\n",
    "    [\"Education: \" + x for x in education_labels_model3] +\n",
    "    [\"Minimum Years Experience\"] +\n",
    "    [\"Is AI Related\"] +\n",
    "    [\"Skill: \" + x.replace(\"has_\", \"\").replace(\"raw_skill_\", \"\").replace(\"_\", \" \").title() for x in skill_cols_model2]\n",
    ")\n",
    "\n",
    "feature_names_model3 = feature_names_model3[:len(importances_model3)]\n",
    "\n",
    "importance_df_model3 = pd.DataFrame({\n",
    "    \"Feature\": feature_names_model3,\n",
    "    \"Importance\": importances_model3[:len(feature_names_model3)]\n",
    "})\n",
    "\n",
    "importance_df_model3 = importance_df_model3[\n",
    "    ~importance_df_model3[\"Feature\"].str.contains(\"unseen\", case=False, na=False)\n",
    "].sort_values(\"Importance\", ascending=False)\n",
    "\n",
    "print(\"\\n=== Model 3: Top 20 Features by Importance (Random Forest) ===\")\n",
    "display(importance_df_model3.head(20))"
