    "\n",
    "coef_plot_df_model1 = coef_df_model1.copy()\n",
    "coef_plot_df_model1[\"abs_coef\"] = coef_plot_df_model1[\"Coefficient\"].abs()\n",
    "\n",
    "top_coef_plot_model1 = (\n",
    "    coef_plot_df_model1\n",
    "    .sort_values(\"abs_coef\", ascending=False)\n",
    "    .head(20)\n",
    "    .sort_values(\"Coefficient\")\n",
    "    .copy()\n",
    ")\n",
    "\n",
    "top_coef_plot_model1[\"direction\"] = top_coef_plot_model1[\"Coefficient\"].apply(\n",
    "    lambda x: \"Positive salary association\" if x > 0 else \"Negative salary association\"\n",
    ")\n",
    "\n",
    "top_coef_plot_model1[\"label\"] = top_coef_plot_model1[\"Coefficient\"].apply(\n",
    "    lambda x: f\"${x:,.0f}\"\n",
    ")\n",
    "\n",
    "def shorten_feature_name_model1(x):\n",
    "    if x.startswith(\"Education: \"):\n",
    "        x = x.replace(\"Education: \", \"Edu: \")\n",
    "        x = x.replace(\"High school or GED\", \"HS/GED\")\n",
    "        x = x.replace(\"Associate degree\", \"Assoc.\")\n",
    "        x = x.replace(\"Bachelor's degree\", \"Bachelor\")\n",
    "        x = x.replace(\"Master's degree\", \"Master\")\n",
    "        x = x.replace(\"Ph.D. or professional degree\", \"PhD\")\n",
    "        x = x.replace(\", \", \" + \")\n",
    "\n",
    "    if x.startswith(\"Title: \"):\n",
    "        title = x.replace(\"Title: \", \"\")\n",
    "        if len(title) > 42:\n",
    "            title = title[:42] + \"...\"\n",
    "        x = \"Title: \" + title\n",
    "\n",
    "    if len(x) > 70:\n",
    "        x = x[:70] + \"...\"\n",
    "\n",
    "    return x\n",
    "\n",
    "top_coef_plot_model1[\"Feature_short\"] = top_coef_plot_model1[\"Feature\"].apply(shorten_feature_name_model1)\n",
    "\n",
    "top_coef_plot_model1[\"Feature_display\"] = top_coef_plot_model1.apply(\n",
    "    lambda r: f\"{r['Feature_short']}  ({r['label']})\",\n",
    "    axis=1\n",
    ")\n",
