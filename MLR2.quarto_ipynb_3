    "    x=\"Coefficient\",\n",
    "    y=\"Feature_display\",\n",
    "    color=\"direction\",\n",
    "    orientation=\"h\",\n",
    "    title=\"Top Salary Predictors by Absolute Coefficient (Model 2)\",\n",
    "    labels={\n",
    "        \"Coefficient\": \"Estimated Salary Impact ($)\",\n",
    "        \"Feature_display\": \"\"\n",
    "    },\n",
    "    color_discrete_map={\n",
    "        \"Positive salary association\": \"#2ca02c\",\n",
    "        \"Negative salary association\": \"#d62728\"\n",
