    "#| echo: false\n",
    "#| warning: false\n",
    "\n",
    "from pyspark.ml.regression import RandomForestRegressor\n",
    "\n",
    "# Model 3 = Model 2's preprocessing, copied and renamed (_model3), with only the\n",
    "# final estimator swapped: LinearRegression -> RandomForestRegressor.\n",
    "\n",
    "title_indexer_model3 = StringIndexer(\n",
    "    inputCol=\"title_grouped\",\n",
    "    outputCol=\"title_idx\",\n",
    "    handleInvalid=\"keep\"\n",
    ")\n",
    "title_encoder_model3 = OneHotEncoder(\n",
    "    inputCol=\"title_idx\",\n",
    "    outputCol=\"title_vec\",\n",
    "    dropLast=False\n",
    ")\n",
    "\n",
    "occupation_group_indexer_model3 = StringIndexer(\n",
    "    inputCol=\"occupation_group_name\",\n",
    "    outputCol=\"occupation_group_idx\",\n",
    "    handleInvalid=\"keep\"\n",
    ")\n",
    "occupation_group_encoder_model3 = OneHotEncoder(\n",
    "    inputCol=\"occupation_group_idx\",\n",
    "    outputCol=\"occupation_group_vec\",\n",
    "    dropLast=False\n",
    ")\n",
    "\n",
    "specialized_occupation_indexer_model3 = StringIndexer(\n",
    "    inputCol=\"specialized_occupation_name\",\n",
    "    outputCol=\"specialized_occupation_idx\",\n",
    "    handleInvalid=\"keep\"\n",
    ")\n",
    "specialized_occupation_encoder_model3 = OneHotEncoder(\n",
    "    inputCol=\"specialized_occupation_idx\",\n",
    "    outputCol=\"specialized_occupation_vec\",\n",
    "    dropLast=False\n",
    ")\n",
    "\n",
    "state_indexer_model3 = StringIndexer(\n",
    "    inputCol=\"state_name\",\n",
    "    outputCol=\"state_idx\",\n",
    "    handleInvalid=\"keep\"\n",
    ")\n",
    "state_encoder_model3 = OneHotEncoder(\n",
    "    inputCol=\"state_idx\",\n",
    "    outputCol=\"state_vec\",\n",
    "    dropLast=False\n",
    ")\n",
    "\n",
    "remote_indexer_model3 = StringIndexer(\n",
    "    inputCol=\"remote_type_name\",\n",
    "    outputCol=\"remote_idx\",\n",
    "    handleInvalid=\"keep\"\n",
    ")\n",
    "remote_encoder_model3 = OneHotEncoder(\n",
    "    inputCol=\"remote_idx\",\n",
    "    outputCol=\"remote_vec\",\n",
    "    dropLast=False\n",
    ")\n",
    "\n",
    "employment_indexer_model3 = StringIndexer(\n",
    "    inputCol=\"employment_type_name\",\n",
    "    outputCol=\"employment_idx\",\n",
    "    handleInvalid=\"keep\"\n",
    ")\n",
    "employment_encoder_model3 = OneHotEncoder(\n",
    "    inputCol=\"employment_idx\",\n",
    "    outputCol=\"employment_vec\",\n",
    "    dropLast=False\n",
    ")\n",
    "\n",
    "education_indexer_model3 = StringIndexer(\n",
    "    inputCol=\"education_level_clean\",\n",
    "    outputCol=\"education_idx\",\n",
    "    handleInvalid=\"keep\"\n",
    ")\n",
    "education_encoder_model3 = OneHotEncoder(\n",
    "    inputCol=\"education_idx\",\n",
    "    outputCol=\"education_vec\",\n",
    "    dropLast=False\n",
    ")\n",
    "\n",
    "assembler_model3 = VectorAssembler(\n",
    "    inputCols=[\n",
    "        \"title_vec\",\n",
    "        \"occupation_group_vec\",\n",
    "        \"specialized_occupation_vec\",\n",
    "        \"state_vec\",\n",
    "        \"remote_vec\",\n",
    "        \"employment_vec\",\n",
    "        \"education_vec\",\n",
    "        \"min_years_experience\",\n",
    "        \"is_ai_related\"\n",
    "    ] + skill_cols_model2,\n",
    "    outputCol=\"features\"\n",
    ")\n",
    "\n",
    "# <-- this is the only conceptual change from Model 2 -->\n",
    "rf_model3_estimator = RandomForestRegressor(\n",
    "    featuresCol=\"features\",\n",
    "    labelCol=\"salary\",\n",
    "    numTrees=100,\n",
    "    maxDepth=10,\n",
    "    seed=42\n",
    ")\n",
    "\n",
    "pipeline_model3 = Pipeline(stages=[\n",
    "    title_indexer_model3, title_encoder_model3,\n",
    "    occupation_group_indexer_model3, occupation_group_encoder_model3,\n",
    "    specialized_occupation_indexer_model3, specialized_occupation_encoder_model3,\n",
    "    state_indexer_model3, state_encoder_model3,\n",
    "    remote_indexer_model3, remote_encoder_model3,\n",
    "    employment_indexer_model3, employment_encoder_model3,\n",
    "    education_indexer_model3, education_encoder_model3,\n",
    "    assembler_model3, rf_model3_estimator\n",
    "])\n",
    "\n",
    "model3 = pipeline_model3.fit(train_model2)\n",
    "\n",
    "predictions_model3 = model3.transform(test_model2)\n",
    "\n",
    "# Model 3 metrics\n",
    "r2_model3 = RegressionEvaluator(\n",
    "    labelCol=\"salary\",\n",
    "    predictionCol=\"prediction\",\n",
    "    metricName=\"r2\"\n",
    ").evaluate(predictions_model3)\n",
    "\n",
    "rmse_model3 = RegressionEvaluator(\n",
    "    labelCol=\"salary\",\n",
    "    predictionCol=\"prediction\",\n",
    "    metricName=\"rmse\"\n",
    ").evaluate(predictions_model3)\n",
    "\n",
    "mae_model3 = RegressionEvaluator(\n",
    "    labelCol=\"salary\",\n",
    "    predictionCol=\"prediction\",\n",
    "    metricName=\"mae\"\n",
    ").evaluate(predictions_model3)\n",
    "\n",
    "rf_model3 = model3.stages[-1]\n",
    "\n",
    "n_model3 = predictions_model3.count()\n",
    "p_model3 = len(rf_model3.featureImportances)\n",
    "\n",
    "adjusted_r2_model3 = (\n",
    "    1 - ((1 - r2_model3) * (n_model3 - 1) / (n_model3 - p_model3 - 1))\n",
    "    if n_model3 > p_model3 + 1\n",
    "    else None\n",
    ")\n",
    "\n",
    "metrics_df_model3 = pd.DataFrame({\n",
    "    \"Metric\": [\"R²\", \"Adjusted R²\", \"RMSE\", \"MAE\"],\n",
    "    \"Value\": [\n",
    "        round(r2_model3, 4),\n",
    "        round(adjusted_r2_model3, 4) if adjusted_r2_model3 is not None else None,\n",
    "        round(rmse_model3, 2),\n",
    "        round(mae_model3, 2)\n",
    "    ]\n",
    "})\n",
    "\n",
    "# print(\"\\n=== Model 3: Random Forest Performance ===\")\n",
    "display(metrics_df_model3)\n",
    "\n",
    "rmse_pct_of_median_model3 = rmse_model3 / salary_stats_model1[\"median_salary\"] * 100\n",
    "mae_pct_of_median_model3 = mae_model3 / salary_stats_model1[\"median_salary\"] * 100\n",
    "print(f\"Model 3 RMSE is {rmse_pct_of_median_model3:.1f}% of median salary\")\n",
    "print(f\"Model 3 MAE is {mae_pct_of_median_model3:.1f}% of median salary\")"
