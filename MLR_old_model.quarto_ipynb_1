      "source": [
        "#| echo: false\n",
        "#| warning: false\n",
        "\n",
        "import json\n",
        "from html import escape\n",
        "from IPython.display import HTML\n",
        "\n",
        "# Collect simple option lists\n",
        "state_options = sorted([x for x in df_model.select(\"state_name\").distinct().toPandas()[\"state_name\"].dropna().tolist()])\n",
        "title_options = sorted([x for x in df_model.select(\"title_grouped\").distinct().toPandas()[\"title_grouped\"].dropna().tolist()])\n",
        "remote_options = sorted([x for x in df_model.select(\"remote_type_name\").distinct().toPandas()[\"remote_type_name\"].dropna().tolist()])\n",
        "employment_options = sorted([x for x in df_model.select(\"employment_type_name\").distinct().toPandas()[\"employment_type_name\"].dropna().tolist()])\n",
        "education_options = sorted([x for x in df_model.select(\"education_level\").distinct().toPandas()[\"education_level\"].dropna().tolist()])\n",
        "\n",
        "# Create coefficient lookup\n",
        "coef_lookup = dict(zip(feature_names, coefficients))\n",
        "\n",
        "payload = {\n",
        "    \"intercept\": float(lr_model.intercept),\n",
        "    \"coef\": {k: float(v) for k, v in coef_lookup.items()},\n",
