        "\n",
        "# Use Multiple Linear Regression to model salary based on location, job title, skills, remote type, employment type, minimum experience, and education level.\n",
        "\n",
        "### Load data"
      ],
      "id": "ca256d2d"
    },
    {
      "cell_type": "code",
      "metadata": {
        "message": false
      },
      "source": [
        "#| echo: false\n",
        "#| warning: false\n",
        "\n",
        "from pyspark.sql import SparkSession\n",
        "from pyspark.sql.functions import col, when, trim, regexp_replace, count as spark_count\n",
        "from pyspark.ml.feature import StringIndexer, OneHotEncoder, VectorAssembler\n",
        "from pyspark.ml.regression import LinearRegression\n",
        "from pyspark.ml import Pipeline\n",
        "from pyspark.ml.evaluation import RegressionEvaluator\n",
        "from IPython.display import display\n",
        "import pandas as pd\n",
        "import plotly.express as px\n",
        "\n",
        "spark = SparkSession.builder \\\n",
        "    .config(\"spark.driver.host\", \"localhost\") \\\n",
        "    .config(\"spark.driver.memory\", \"4g\") \\\n",
        "    .config(\"spark.executor.memory\", \"4g\") \\\n",
        "    .appName(\"SalaryMLR\") \\\n",
        "    .getOrCreate()\n",
        "\n",
        "spark.catalog.clearCache()\n",
        "spark.sparkContext.setLogLevel(\"ERROR\")\n",
        "\n",
        "# Load prepared model-ready dataset from data_cleaning.qmd\n",
        "df_model_base = spark.read.parquet(\"data/prepared/salary_regression_data.parquet\")\n",
        "skill_count_features_df = spark.read.parquet(\"data/prepared/skill_count_features.parquet\")\n",
        "\n",
        "df_model_base = df_model_base.join(\n",
        "    skill_count_features_df,\n",
        "    df_model_base.id == skill_count_features_df.job_id,\n",
        "    how=\"left\"\n",
        ").drop(\"job_id\")\n",
        "\n",
        "# Add education level from cleaned dataset\n",
        "education_df = (\n",
        "    spark.read.parquet(\"data/cleaned/lightcast_cleaned.parquet\")\n",
        "    .select(\n",
        "        col(\"ID\").alias(\"id\"),\n",
        "        col(\"EDUCATION_LEVELS_NAME\").alias(\"education_level\")\n",
        "    )\n",
        "    .dropDuplicates([\"id\"])\n",
        ")\n",
        "\n",
        "df_model_base = (\n",
        "    df_model_base\n",
        "    .join(education_df, on=\"id\", how=\"left\")\n",
        "    .withColumn(\n",
        "        \"education_level\",\n",
        "        trim(\n",
        "            regexp_replace(\n",
        "                regexp_replace(col(\"education_level\"), r\"[\\n\\r]\", \" \"),\n",
        "                r\"\\s+\",\n",
        "                \" \"\n",
        "            )\n",
        "        )\n",
        "    )\n",
        "    .fillna({\"education_level\": \"Unknown\"})\n",
        ")\n",
        "\n",
        "# Keep only valid salary rows\n",
        "df_salary = df_model_base.filter(\n",
        "    col(\"salary\").isNotNull() &\n",
        "    (col(\"salary\") > 0) &\n",
        "    (col(\"salary\") <= 500000)\n",
        ").cache()\n",
        "\n",
        "# Group job titles using top 30 titles, same idea as friend's model\n",
        "top_titles = [\n",
        "    r[\"title_clean\"] for r in\n",
        "    df_salary.groupBy(\"title_clean\")\n",
        "    .agg(spark_count(\"*\").alias(\"cnt\"))\n",
        "    .orderBy(col(\"cnt\").desc())\n",
        "    .limit(30)\n",
        "    .collect()\n",
        "]\n",
        "\n",
        "df_model = df_salary.withColumn(\n",
        "    \"title_grouped\",\n",
        "    when(col(\"title_clean\").isin(top_titles), col(\"title_clean\")).otherwise(\"Other\")\n",
        ")\n",
        "\n",
        "# Actual skill flags prepared in data_cleaning.qmd\n",
        "skill_cols = [\n",
        "    \"has_python\",\n",
        "    \"has_sql\",\n",
        "    \"has_machine_learning\",\n",
        "    \"has_tableau\",\n",
        "    \"has_power_bi\",\n",
        "    \"has_aws\",\n",
        "    \"has_excel\",\n",
        "    \"has_sap\",\n",
        "    \"common_skill_count\",\n",
        "    \"specialized_skill_count\",\n",
        "    \"software_skill_count\"\n",
        "]\n",
        "\n",
        "# Select seven feature groups:\n",
        "# 1 location, 2 job title, 3 skills, 4 remote type, 5 employment type, 6 min experience, 7 education\n",
        "df_model = (\n",
        "    df_model\n",
        "    .select(\n",
        "        [\"salary\",\n",
        "         \"state_name\",\n",
        "         \"title_grouped\",\n",
        "         \"remote_type_name\",\n",
        "         \"employment_type_name\",\n",
        "         \"min_years_experience\",\n",
        "         \"education_level\"] + skill_cols\n",
        "    )\n",
        "    .fillna({\n",
        "    \"state_name\": \"Unknown\",\n",
        "    \"title_grouped\": \"Other\",\n",
        "    \"remote_type_name\": \"Unknown\",\n",
        "    \"employment_type_name\": \"Unknown\",\n",
        "    \"min_years_experience\": 0,\n",
        "    \"education_level\": \"Unknown\",\n",
        "    \"has_python\": 0,\n",
        "    \"has_sql\": 0,\n",
        "    \"has_machine_learning\": 0,\n",
        "    \"has_tableau\": 0,\n",
        "    \"has_power_bi\": 0,\n",
        "    \"has_aws\": 0,\n",
        "    \"has_excel\": 0,\n",
        "    \"has_sap\": 0,\n",
        "    \"common_skill_count\": 0,\n",
        "    \"specialized_skill_count\": 0,\n",
        "    \"software_skill_count\": 0\n",
        "    })\n",
        ".cache())\n",
        "\n",
        "print(\"Model rows:\", df_model.count())\n",
        "print(\"Top 30 grouped titles:\", top_titles[:10], \"...\")\n",
        "\n",
        "# Categorical encoders\n",
        "title_indexer = StringIndexer(\n",
        "    inputCol=\"title_grouped\",\n",
        "    outputCol=\"title_idx\",\n",
        "    handleInvalid=\"keep\"\n",
        ")\n",
        "title_encoder = OneHotEncoder(\n",
        "    inputCol=\"title_idx\",\n",
        "    outputCol=\"title_vec\",\n",
        "    dropLast=False\n",
        ")\n",
        "\n",
        "state_indexer = StringIndexer(\n",
        "    inputCol=\"state_name\",\n",
        "    outputCol=\"state_idx\",\n",
        "    handleInvalid=\"keep\"\n",
        ")\n",
        "state_encoder = OneHotEncoder(\n",
        "    inputCol=\"state_idx\",\n",
        "    outputCol=\"state_vec\",\n",
        "    dropLast=False\n",
        ")\n",
        "\n",
        "remote_indexer = StringIndexer(\n",
        "    inputCol=\"remote_type_name\",\n",
        "    outputCol=\"remote_idx\",\n",
        "    handleInvalid=\"keep\"\n",
        ")\n",
        "remote_encoder = OneHotEncoder(\n",
        "    inputCol=\"remote_idx\",\n",
        "    outputCol=\"remote_vec\",\n",
        "    dropLast=False\n",
        ")\n",
        "\n",
        "employment_indexer = StringIndexer(\n",
        "    inputCol=\"employment_type_name\",\n",
        "    outputCol=\"employment_idx\",\n",
        "    handleInvalid=\"keep\"\n",
        ")\n",
        "employment_encoder = OneHotEncoder(\n",
        "    inputCol=\"employment_idx\",\n",
        "    outputCol=\"employment_vec\",\n",
        "    dropLast=False\n",
        ")\n",
        "\n",
        "education_indexer = StringIndexer(\n",
        "    inputCol=\"education_level\",\n",
        "    outputCol=\"education_idx\",\n",
        "    handleInvalid=\"keep\"\n",
        ")\n",
        "education_encoder = OneHotEncoder(\n",
        "    inputCol=\"education_idx\",\n",
        "    outputCol=\"education_vec\",\n",
        "    dropLast=False\n",
        ")\n",
        "\n",
        "assembler = VectorAssembler(\n",
        "    inputCols=[\n",
        "        \"title_vec\",\n",
        "        \"state_vec\",\n",
        "        \"remote_vec\",\n",
        "        \"employment_vec\",\n",
        "        \"education_vec\",\n",
        "        \"min_years_experience\"\n",
        "    ] + skill_cols,\n",
        "    outputCol=\"features\"\n",
        ")\n",
        "\n",
        "lr = LinearRegression(\n",
        "    featuresCol=\"features\",\n",
        "    labelCol=\"salary\"\n",
        ")\n",
        "\n",
        "pipeline = Pipeline(stages=[\n",
        "    title_indexer, title_encoder,\n",
        "    state_indexer, state_encoder,\n",
        "    remote_indexer, remote_encoder,\n",
        "    employment_indexer, employment_encoder,\n",
        "    education_indexer, education_encoder,\n",
        "    assembler, lr\n",
        "])\n",
        "\n",
        "train, test = df_model.randomSplit([0.8, 0.2], seed=42)\n",
        "\n",
        "model = pipeline.fit(train)\n",
        "predictions = model.transform(test)\n",
        "\n",
        "# Metrics\n",
        "r2 = RegressionEvaluator(\n",
        "    labelCol=\"salary\",\n",
        "    predictionCol=\"prediction\",\n",
        "    metricName=\"r2\"\n",
        ").evaluate(predictions)\n",
        "\n",
        "rmse = RegressionEvaluator(\n",
        "    labelCol=\"salary\",\n",
        "    predictionCol=\"prediction\",\n",
        "    metricName=\"rmse\"\n",
        ").evaluate(predictions)\n",
        "\n",
        "mae = RegressionEvaluator(\n",
        "    labelCol=\"salary\",\n",
        "    predictionCol=\"prediction\",\n",
        "    metricName=\"mae\"\n",
        ").evaluate(predictions)\n",
        "\n",
        "lr_model = model.stages[-1]\n",
        "n = predictions.count()\n",
        "p = len(lr_model.coefficients)\n",
        "\n",
        "adjusted_r2 = 1 - ((1 - r2) * (n - 1) / (n - p - 1)) if n > p + 1 else None\n",
        "\n",
        "metrics_df = pd.DataFrame({\n",
        "    \"Metric\": [\"R²\", \"Adjusted R²\", \"RMSE\", \"MAE\"],\n",
        "    \"Value\": [\n",
        "        round(r2, 4),\n",
        "        round(adjusted_r2, 4) if adjusted_r2 is not None else None,\n",
        "        round(rmse, 2),\n",
        "        round(mae, 2)\n",
        "    ]\n",
        "})\n",
        "\n",
        "display(metrics_df)\n",
        "\n",
        "# Coefficient table\n",
        "coefficients = lr_model.coefficients.toArray()\n",
        "\n",
        "title_labels = list(model.stages[0].labels) + [\"title_unseen\"]\n",
        "state_labels = list(model.stages[2].labels) + [\"state_unseen\"]\n",
        "remote_labels = list(model.stages[4].labels) + [\"remote_unseen\"]\n",
        "employment_labels = list(model.stages[6].labels) + [\"employment_unseen\"]\n",
        "education_labels = list(model.stages[8].labels) + [\"education_unseen\"]\n",
        "\n",
        "feature_names = (\n",
        "    [\"Title: \" + x for x in title_labels] +\n",
        "    [\"State: \" + x for x in state_labels] +\n",
        "    [\"Remote: \" + x for x in remote_labels] +\n",
        "    [\"Employment: \" + x for x in employment_labels] +\n",
        "    [\"Education: \" + x for x in education_labels] +\n",
        "    [\"Minimum Years Experience\"] +\n",
        "    [\"Skill: \" + x.replace(\"has_\", \"\").replace(\"_\", \" \").title() for x in skill_cols]\n",
        ")\n",
        "\n",
        "feature_names = feature_names[:len(coefficients)]\n",
        "\n",
        "coef_df = pd.DataFrame({\n",
        "    \"Feature\": feature_names,\n",
        "    \"Coefficient\": coefficients\n",
        "})\n",
        "\n",
        "coef_df = coef_df[\n",
        "    ~coef_df[\"Feature\"].str.contains(\"unseen\", case=False, na=False)\n",
        "].sort_values(\"Coefficient\", ascending=False)\n",
        "\n",
        "print(\"\\n=== Salary Impact by Feature ===\")\n",
        "display(coef_df)\n",
        "\n",
        "print(f\"\\nIntercept: ${lr_model.intercept:,.0f}\")\n",
        "print(f\"Test R²: {r2:.4f}\")\n",
        "print(f\"Test Adjusted R²: {adjusted_r2:.4f}\" if adjusted_r2 is not None else \"Adjusted R²: not available\")"
      ],
      "id": "a9d3bc9c",
      "execution_count": null,
      "outputs": []
    },
