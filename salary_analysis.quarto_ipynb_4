   "source": [
    "state_salary = spark.sql(\"\"\"\n",
    "SELECT\n",
    "    l.state_name,\n",
    "    CASE\n",
    "        WHEN a.job_id IS NOT NULL THEN 'AI-related'\n",
    "        ELSE 'Non-AI'\n",
    "    END AS career_type,\n",
    "    ROUND(AVG(CAST(j.salary AS DOUBLE)),0) AS avg_salary,\n",
    "    COUNT(*) AS postings\n",
    "FROM job_postings j\n",
    "LEFT JOIN ai_job_ids a\n",
    "    ON j.id = a.job_id\n",
    "LEFT JOIN locations l\n",
    "    ON j.location_id = l.location_id\n",
    "WHERE\n",
    "    j.salary IS NOT NULL\n",
    "    AND CAST(j.salary AS DOUBLE) > 0\n",
    "    AND l.state_name IS NOT NULL\n",
    "GROUP BY\n",
    "    l.state_name,\n",
    "    CASE\n",
    "        WHEN a.job_id IS NOT NULL THEN 'AI-related'\n",
    "        ELSE 'Non-AI'\n",
    "    END\n",
    "HAVING COUNT(*) >= 30\n",
    "\"\"\")\n",
    "\n",
    "state_salary_pd = state_salary.toPandas()\n",
    "\n",
    "from us import states\n",
    "\n",
    "state_salary_pd[\"state_code\"] = (\n",
    "    state_salary_pd[\"state_name\"]\n",
    "    .apply(lambda x: states.lookup(x).abbr if states.lookup(x) else None)\n",
    ")\n",
    "\n",
    "import plotly.express as px\n",
    "\n",
    "ai_map = state_salary_pd[\n",
    "    state_salary_pd[\"career_type\"] == \"AI-related\"\n",
    "]\n",
    "\n",
    "fig = px.choropleth(\n",
    "    ai_map,\n",
    "    locations=\"state_code\",\n",
    "    locationmode=\"USA-states\",\n",
    "    color=\"avg_salary\",\n",
    "    scope=\"usa\",\n",
    "    hover_name=\"state_name\",\n",
    "    title=\"Average AI Salary by State\"\n",
    ")\n",
    "\n",
    "fig.show()"
   ]
  },
