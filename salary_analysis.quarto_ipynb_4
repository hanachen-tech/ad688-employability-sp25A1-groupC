   "source": [
    "remote_salary = spark.sql(\"\"\"\n",
    "SELECT\n",
    "    COALESCE(remote_type_name,'Unknown') AS remote_type,\n",
    "    ROUND(AVG(CAST(salary AS DOUBLE)),0) AS avg_salary,\n",
    "    COUNT(*) AS postings\n",
    "FROM job_postings\n",
    "WHERE\n",
    "    salary IS NOT NULL\n",
    "    AND CAST(salary AS DOUBLE) > 0\n",
    "GROUP BY remote_type_name\n",
    "ORDER BY avg_salary DESC\n",
    "\"\"\")\n",
    "\n",
    "remote_salary_pd = remote_salary.toPandas()\n",
    "\n",
    "fig = px.bar(\n",
    "    remote_salary_pd,\n",
    "    x=\"remote_type\",\n",
    "    y=\"avg_salary\",\n",
    "    color=\"remote_type\",\n",
    "    text=\"avg_salary\",\n",
    "    title=\"Average Salary by Remote Work Arrangement\"\n",
    ")\n",
    "\n",
    "fig.update_traces(\n",
    "    texttemplate=\"$%{text:,.0f}\",\n",
    "    textposition=\"outside\"\n",
    ")\n",
    "\n",
    "fig.update_layout(\n",
    "    template=\"plotly_white\",\n",
    "    showlegend=False\n",
    ")\n",
    "\n",
    "fig.show()"
   ]
