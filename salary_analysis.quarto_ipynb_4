    "#| echo: true\n",
    "#| output: false\n",
    "#| warning: false\n",
    "\n",
    "from pyspark.sql import SparkSession\n",
    "from pyspark.sql.functions import col, monotonically_increasing_id\n",
    "\n",
    "spark = SparkSession.builder \\\n",
    "    .config(\"spark.driver.host\", \"localhost\") \\\n",
    "    .appName(\"SalaryCompensationTrends\") \\\n",
    "    .getOrCreate()\n",
    "\n",
    "spark.catalog.clearCache()\n",
    "\n",
    "# Load cleaned dataset from data_cleaning.qmd\n",
    "df_clean = spark.read.parquet(\"data/cleaned/lightcast_cleaned.parquet\")\n",
    "df_clean.createOrReplaceTempView(\"raw_jobs_clean\")\n",
    "\n",
    "print(\"Cleaned rows:\", df_clean.count())\n",
    "print(\"Cleaned columns:\", len(df_clean.columns))\n",
    "print(\"Has imputed salary column:\", \"ANALYSIS_SALARY_INDUSTRY_IMPUTED\" in df_clean.columns)\n",
    "\n",
    "# companies table\n",
    "companies_df = df_clean.select(\n",
    "    col(\"COMPANY\").alias(\"company_id\"),\n",
    "    col(\"COMPANY\").alias(\"company\"),\n",
    "    col(\"COMPANY_NAME\").alias(\"company_name\"),\n",
    "    col(\"COMPANY_RAW\").alias(\"company_raw\"),\n",
    "    col(\"COMPANY_IS_STAFFING\").alias(\"company_is_staffing\")\n",
    ").dropDuplicates([\"company_id\"])\n",
    "\n",
    "companies_df.createOrReplaceTempView(\"companies\")\n",
    "\n",
    "# industries table\n",
    "industries_df = df_clean.select(\n",
    "    col(\"NAICS_2022_6\").alias(\"naics_2022_6\"),\n",
    "    col(\"NAICS_2022_6_NAME\").alias(\"naics_2022_6_name\")\n",
    ").dropDuplicates()\n",
    "\n",
    "industries_df = industries_df.withColumn(\n",
    "    \"industry_id\",\n",
    "    monotonically_increasing_id()\n",
    ")\n",
    "\n",
    "industries_df = industries_df.select(\n",
    "    \"industry_id\",\n",
    "    \"naics_2022_6\",\n",
    "    \"naics_2022_6_name\"\n",
    ")\n",
    "\n",
    "industries_df.createOrReplaceTempView(\"industries\")\n",
    "\n",
    "# locations table\n",
    "locations_df = df_clean.select(\n",
    "    col(\"LOCATION\").alias(\"location\"),\n",
    "    col(\"CITY_NAME\").alias(\"city_name\"),\n",
    "    col(\"STATE_NAME\").alias(\"state_name\"),\n",
    "    col(\"COUNTY_NAME\").alias(\"county_name\"),\n",
    "    col(\"MSA\").alias(\"msa\"),\n",
    "    col(\"MSA_NAME\").alias(\"msa_name\")\n",
    ").dropDuplicates()\n",
    "\n",
    "locations_df = locations_df.withColumn(\n",
    "    \"location_id\",\n",
    "    monotonically_increasing_id()\n",
    ")\n",
    "\n",
    "locations_df = locations_df.select(\n",
    "    \"location_id\",\n",
    "    \"location\",\n",
    "    \"city_name\",\n",
    "    \"state_name\",\n",
    "    \"county_name\",\n",
    "    \"msa\",\n",
    "    \"msa_name\"\n",
    ")\n",
    "\n",
    "locations_df.createOrReplaceTempView(\"locations\")\n",
    "\n",
    "# occupations table\n",
    "occupations_df = df_clean.select(\n",
    "    col(\"SOC_5\").alias(\"soc_5\"),\n",
    "    col(\"SOC_5_NAME\").alias(\"soc_5_name\"),\n",
    "    col(\"LOT_SPECIALIZED_OCCUPATION\").alias(\"specialized_occupation\"),\n",
    "    col(\"LOT_SPECIALIZED_OCCUPATION_NAME\").alias(\"specialized_occupation_name\"),\n",
    "    col(\"LOT_OCCUPATION_GROUP\").alias(\"occupation_group\"),\n",
    "    col(\"LOT_OCCUPATION_GROUP_NAME\").alias(\"occupation_group_name\")\n",
    ").dropDuplicates()\n",
    "\n",
    "occupations_df = occupations_df.withColumn(\n",
    "    \"occupation_id\",\n",
    "    monotonically_increasing_id()\n",
    ")\n",
    "\n",
    "occupations_df = occupations_df.select(\n",
    "    \"occupation_id\",\n",
    "    \"soc_5\",\n",
    "    \"soc_5_name\",\n",
    "    \"specialized_occupation\",\n",
    "    \"specialized_occupation_name\",\n",
    "    \"occupation_group\",\n",
    "    \"occupation_group_name\"\n",
    ")\n",
    "\n",
    "occupations_df.createOrReplaceTempView(\"occupations\")\n",
    "\n",
    "# job postings table\n",
    "job_with_industry = df_clean.join(\n",
    "    industries_df,\n",
    "    (\n",
    "        (df_clean[\"NAICS_2022_6\"] == industries_df[\"naics_2022_6\"]) &\n",
    "        (df_clean[\"NAICS_2022_6_NAME\"] == industries_df[\"naics_2022_6_name\"])\n",
    "    ),\n",
    "    \"left\"\n",
    ")\n",
    "\n",
    "job_with_location = job_with_industry.join(\n",
    "    locations_df,\n",
    "    (\n",
    "        (job_with_industry[\"LOCATION\"] == locations_df[\"location\"]) &\n",
    "        (job_with_industry[\"CITY_NAME\"] == locations_df[\"city_name\"]) &\n",
    "        (job_with_industry[\"STATE_NAME\"] == locations_df[\"state_name\"]) &\n",
    "        (job_with_industry[\"COUNTY_NAME\"] == locations_df[\"county_name\"]) &\n",
    "        (job_with_industry[\"MSA\"] == locations_df[\"msa\"]) &\n",
    "        (job_with_industry[\"MSA_NAME\"] == locations_df[\"msa_name\"])\n",
    "    ),\n",
    "    \"left\"\n",
    ")\n",
    "\n",
    "job_with_keys = job_with_location.join(\n",
    "    occupations_df,\n",
    "    (\n",
    "        (job_with_location[\"SOC_5\"] == occupations_df[\"soc_5\"]) &\n",
    "        (job_with_location[\"SOC_5_NAME\"] == occupations_df[\"soc_5_name\"]) &\n",
    "        (job_with_location[\"LOT_SPECIALIZED_OCCUPATION\"] == occupations_df[\"specialized_occupation\"]) &\n",
    "        (job_with_location[\"LOT_SPECIALIZED_OCCUPATION_NAME\"] == occupations_df[\"specialized_occupation_name\"]) &\n",
    "        (job_with_location[\"LOT_OCCUPATION_GROUP\"] == occupations_df[\"occupation_group\"]) &\n",
    "        (job_with_location[\"LOT_OCCUPATION_GROUP_NAME\"] == occupations_df[\"occupation_group_name\"])\n",
    "    ),\n",
    "    \"left\"\n",
    ")\n",
    "\n",
    "job_postings_df = job_with_keys.select(\n",
    "    job_with_keys[\"ID\"].alias(\"id\"),\n",
    "    job_with_keys[\"TITLE_CLEAN\"].alias(\"title_clean\"),\n",
    "    job_with_keys[\"COMPANY\"].alias(\"company_id\"),\n",
    "    col(\"industry_id\"),\n",
    "    col(\"occupation_id\"),\n",
    "    job_with_keys[\"EMPLOYMENT_TYPE_NAME\"].alias(\"employment_type_name\"),\n",
    "    job_with_keys[\"REMOTE_TYPE_NAME\"].alias(\"remote_type_name\"),\n",
    "    job_with_keys[\"BODY\"].alias(\"body\"),\n",
    "    job_with_keys[\"MIN_YEARS_EXPERIENCE\"].alias(\"min_years_experience\"),\n",
    "    job_with_keys[\"MAX_YEARS_EXPERIENCE\"].alias(\"max_years_experience\"),\n",
    "    job_with_keys[\"SALARY\"].alias(\"original_salary\"),\n",
    "    job_with_keys[\"SALARY_FROM\"].alias(\"salary_from\"),\n",
    "    job_with_keys[\"SALARY_TO\"].alias(\"salary_to\"),\n",
    "    job_with_keys[\"ANALYSIS_SALARY\"].alias(\"observed_analysis_salary\"),\n",
    "    job_with_keys[\"ANALYSIS_SALARY_INDUSTRY_IMPUTED\"].alias(\"salary\"),\n",
    "    job_with_keys[\"SALARY_IMPUTATION_STATUS\"].alias(\"salary_imputation_status\"),\n",
    "    col(\"location_id\"),\n",
    "    job_with_keys[\"POSTED_DATE\"].alias(\"posted_date\"),\n",
    "    job_with_keys[\"POSTED\"].alias(\"posted\"),\n",
    "    job_with_keys[\"EXPIRED\"].alias(\"expired\"),\n",
    "    job_with_keys[\"DURATION\"].alias(\"duration\")\n",
    ").filter(\n",
    "    col(\"id\").isNotNull()\n",
    ").dropDuplicates([\"id\"])\n",
    "\n",
    "job_postings_df.createOrReplaceTempView(\"job_postings\")"
   ]
