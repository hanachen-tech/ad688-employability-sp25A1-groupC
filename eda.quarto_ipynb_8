    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "**Insight:** After industry-median imputation, 39,244 postings have usable salary values and 33,232 postings remain missing salary. This increases the salary sample size compared with the original `ANALYSIS_SALARY` variable, which had 32,394 observed salary values.\n",
        "\n",
        "## Salary Missingness Bias Check\n",
        "\n",
        "This section checks whether salary availability still differs across important groups after using the imputed salary variable. This helps identify whether salary-based results may still be affected by missing salary patterns."
      ],
      "id": "a7ff6673"
    },
    {
      "cell_type": "code",
      "metadata": {
        "message": false
      },
      "source": [
        "#| echo: true\n",
        "#| warning: false\n",
        "\n",
        "salary_missing_by_ai = spark.sql(\"\"\"\n",
        "SELECT\n",
        "    career_type,\n",
        "    COUNT(DISTINCT id) AS total_postings,\n",
        "    COUNT(DISTINCT CASE\n",
        "        WHEN salary IS NOT NULL AND salary > 0\n",
        "        THEN id\n",
        "    END) AS salary_available,\n",
        "    COUNT(DISTINCT CASE\n",
        "        WHEN salary IS NULL OR salary <= 0\n",
        "        THEN id\n",
        "    END) AS salary_missing,\n",
        "    ROUND(\n",
        "        COUNT(DISTINCT CASE\n",
        "            WHEN salary IS NULL OR salary <= 0\n",
        "            THEN id\n",
        "        END) / COUNT(DISTINCT id) * 100,\n",
        "        2\n",
        "    ) AS missing_salary_percent\n",
        "FROM jobs_with_ai\n",
        "GROUP BY career_type\n",
        "ORDER BY missing_salary_percent DESC\n",
        "\"\"\").toPandas()\n",
        "\n",
        "display(style_table(salary_missing_by_ai, {\n",
        "    \"total_postings\": \"{:,.0f}\",\n",
        "    \"salary_available\": \"{:,.0f}\",\n",
        "    \"salary_missing\": \"{:,.0f}\",\n",
        "    \"missing_salary_percent\": \"{:.2f}%\"\n",
        "}))\n",
        "\n",
        "\n",
        "salary_missing_by_remote = spark.sql(\"\"\"\n",
        "SELECT\n",
        "    remote_type_name AS remote_type,\n",
        "    COUNT(DISTINCT id) AS total_postings,\n",
        "    COUNT(DISTINCT CASE\n",
        "        WHEN salary IS NOT NULL AND salary > 0\n",
        "        THEN id\n",
        "    END) AS salary_available,\n",
        "    COUNT(DISTINCT CASE\n",
        "        WHEN salary IS NULL OR salary <= 0\n",
        "        THEN id\n",
        "    END) AS salary_missing,\n",
        "    ROUND(\n",
        "        COUNT(DISTINCT CASE\n",
        "            WHEN salary IS NULL OR salary <= 0\n",
        "            THEN id\n",
        "        END) / COUNT(DISTINCT id) * 100,\n",
        "        2\n",
        "    ) AS missing_salary_percent\n",
        "FROM job_postings\n",
        "WHERE remote_type_name IS NOT NULL\n",
        "GROUP BY remote_type_name\n",
        "ORDER BY missing_salary_percent DESC\n",
        "\"\"\").toPandas()\n",
        "\n",
        "display(style_table(salary_missing_by_remote, {\n",
        "    \"total_postings\": \"{:,.0f}\",\n",
        "    \"salary_available\": \"{:,.0f}\",\n",
        "    \"salary_missing\": \"{:,.0f}\",\n",
        "    \"missing_salary_percent\": \"{:.2f}%\"\n",
        "}))\n",
        "\n",
        "\n",
        "salary_missing_by_state = spark.sql(\"\"\"\n",
        "SELECT\n",
        "    l.state_name,\n",
        "    COUNT(DISTINCT j.id) AS total_postings,\n",
        "    COUNT(DISTINCT CASE\n",
        "        WHEN j.salary IS NOT NULL AND j.salary > 0\n",
        "        THEN j.id\n",
        "    END) AS salary_available,\n",
        "    COUNT(DISTINCT CASE\n",
        "        WHEN j.salary IS NULL OR j.salary <= 0\n",
        "        THEN j.id\n",
        "    END) AS salary_missing,\n",
        "    ROUND(\n",
        "        COUNT(DISTINCT CASE\n",
        "            WHEN j.salary IS NULL OR j.salary <= 0\n",
        "            THEN j.id\n",
        "        END) / COUNT(DISTINCT j.id) * 100,\n",
        "        2\n",
        "    ) AS missing_salary_percent\n",
        "FROM job_postings j\n",
        "LEFT JOIN locations l\n",
        "    ON j.location_id = l.location_id\n",
        "WHERE l.state_name IS NOT NULL\n",
        "GROUP BY l.state_name\n",
        "HAVING COUNT(DISTINCT j.id) >= 100\n",
        "ORDER BY missing_salary_percent DESC\n",
        "LIMIT 20\n",
        "\"\"\").toPandas()\n",
        "\n",
        "display(style_table(salary_missing_by_state, {\n",
        "    \"total_postings\": \"{:,.0f}\",\n",
        "    \"salary_available\": \"{:,.0f}\",\n",
        "    \"salary_missing\": \"{:,.0f}\",\n",
        "    \"missing_salary_percent\": \"{:.2f}%\"\n",
        "}))\n",
        "\n",
        "\n",
        "salary_missing_by_industry = spark.sql(\"\"\"\n",
        "SELECT\n",
        "    i.naics_2022_6_name AS industry,\n",
        "    COUNT(DISTINCT j.id) AS total_postings,\n",
        "    COUNT(DISTINCT CASE\n",
        "        WHEN j.salary IS NOT NULL AND j.salary > 0\n",
        "        THEN j.id\n",
        "    END) AS salary_available,\n",
        "    COUNT(DISTINCT CASE\n",
        "        WHEN j.salary IS NULL OR j.salary <= 0\n",
        "        THEN j.id\n",
        "    END) AS salary_missing,\n",
        "    ROUND(\n",
        "        COUNT(DISTINCT CASE\n",
        "            WHEN j.salary IS NULL OR j.salary <= 0\n",
        "            THEN j.id\n",
        "        END) / COUNT(DISTINCT j.id) * 100,\n",
        "        2\n",
        "    ) AS missing_salary_percent\n",
        "FROM job_postings j\n",
        "LEFT JOIN industries i\n",
        "    ON j.industry_id = i.industry_id\n",
        "WHERE i.naics_2022_6_name IS NOT NULL\n",
        "GROUP BY i.naics_2022_6_name\n",
        "HAVING COUNT(DISTINCT j.id) >= 100\n",
        "ORDER BY missing_salary_percent DESC\n",
        "LIMIT 20\n",
        "\"\"\").toPandas()\n",
        "\n",
        "display(style_table(salary_missing_by_industry, {\n",
        "    \"total_postings\": \"{:,.0f}\",\n",
        "    \"salary_available\": \"{:,.0f}\",\n",
        "    \"salary_missing\": \"{:,.0f}\",\n",
        "    \"missing_salary_percent\": \"{:.2f}%\"\n",
        "}))"
      ],
      "id": "e223004b",
      "execution_count": null,
      "outputs": []
    },
    {
