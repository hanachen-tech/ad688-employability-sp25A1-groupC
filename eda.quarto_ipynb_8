        "# Exploratory Data Analysis\n",
        "\n",
        "## Overview\n",
        "\n",
        "This page explores the cleaned Lightcast job postings dataset created in the data preparation step. The purpose of this exploratory analysis is to understand the overall size of the dataset, salary availability, remote-work categories, geographic distribution, and industry distribution before moving into the main research analysis.\n",
        "\n",
        "## 1. Load Cleaned Data"
      ],
      "id": "3f163614"
    },
    {
      "cell_type": "code",
      "metadata": {
        "message": false
      },
      "source": [
        "#| echo: true\n",
        "#| warning: false\n",
        "\n",
        "from pyspark.sql import SparkSession\n",
        "from IPython.display import display\n",
        "import pandas as pd\n",
        "import plotly.express as px\n",
        "\n",
        "spark = SparkSession.builder \\\n",
        "    .config(\"spark.driver.host\", \"localhost\") \\\n",
        "    .appName(\"EDAJobMarket\") \\\n",
        "    .getOrCreate()\n",
        "\n",
        "spark.catalog.clearCache()\n",
        "\n",
        "# Load prepared tables created by data_cleaning.qmd\n",
        "job_postings_df = spark.read.parquet(\"data/prepared/job_postings.parquet\")\n",
        "companies_df = spark.read.parquet(\"data/prepared/companies.parquet\")\n",
        "industries_df = spark.read.parquet(\"data/prepared/industries.parquet\")\n",
        "locations_df = spark.read.parquet(\"data/prepared/locations.parquet\")\n",
        "occupations_df = spark.read.parquet(\"data/prepared/occupations.parquet\")\n",
        "skills_df = spark.read.parquet(\"data/prepared/skills.parquet\")\n",
        "job_skill_matches_df = spark.read.parquet(\"data/prepared/job_skill_matches.parquet\")\n",
        "ai_job_ids = spark.read.parquet(\"data/prepared/ai_job_ids.parquet\")\n",
        "jobs_with_ai = spark.read.parquet(\"data/prepared/jobs_with_ai.parquet\")\n",
        "salary_regression_data = spark.read.parquet(\"data/prepared/salary_regression_data.parquet\")\n",
        "salary_classification_data = spark.read.parquet(\"data/prepared/salary_classification_data.parquet\")\n",
        "\n",
        "# Register Spark SQL views\n",
        "job_postings_df.createOrReplaceTempView(\"job_postings\")\n",
        "companies_df.createOrReplaceTempView(\"companies\")\n",
        "industries_df.createOrReplaceTempView(\"industries\")\n",
        "locations_df.createOrReplaceTempView(\"locations\")\n",
        "occupations_df.createOrReplaceTempView(\"occupations\")\n",
        "skills_df.createOrReplaceTempView(\"skills\")\n",
        "job_skill_matches_df.createOrReplaceTempView(\"job_skill_matches\")\n",
        "ai_job_ids.createOrReplaceTempView(\"ai_job_ids\")\n",
        "jobs_with_ai.createOrReplaceTempView(\"jobs_with_ai\")\n",
        "salary_regression_data.createOrReplaceTempView(\"salary_regression_data\")\n",
        "salary_classification_data.createOrReplaceTempView(\"salary_classification_data\")\n",
        "\n",
        "def style_table(df, format_dict=None):\n",
        "    styled = df.style\n",
        "    if format_dict is not None:\n",
        "        styled = styled.format(format_dict)\n",
        "    styled = styled.set_properties(**{\n",
        "        \"text-align\": \"left\",\n",
        "        \"white-space\": \"normal\",\n",
        "        \"border\": \"1px solid #ddd\",\n",
        "        \"padding\": \"6px\"\n",
        "    }).set_table_styles([\n",
        "        {\"selector\": \"th\", \"props\": [\n",
        "            (\"background-color\", \"#f6f8fa\"),\n",
        "            (\"color\", \"#24324b\"),\n",
        "            (\"font-weight\", \"bold\"),\n",
        "            (\"border\", \"1px solid #ddd\"),\n",
        "            (\"padding\", \"8px\")\n",
        "        ]},\n",
        "        {\"selector\": \"td\", \"props\": [\n",
        "            (\"border\", \"1px solid #ddd\"),\n",
        "            (\"padding\", \"6px\")\n",
        "        ]},\n",
        "        {\"selector\": \"table\", \"props\": [\n",
        "            (\"border-collapse\", \"collapse\"),\n",
        "            (\"width\", \"100%\")\n",
        "        ]}\n",
        "    ])\n",
        "    return styled\n",
        "\n",
        "print(\"Prepared job postings rows:\", job_postings_df.count())\n",
        "print(\"Regression-ready rows:\", salary_regression_data.count())\n",
        "print(\"Classification-ready rows:\", salary_classification_data.count())"
      ],
