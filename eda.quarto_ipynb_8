        "## 5. Salary Availability After Imputation\n",
        "\n",
        "This section checks salary coverage using `ANALYSIS_SALARY_INDUSTRY_IMPUTED`, which combines observed salary values with qualified industry-median imputed salary values. This variable is used as the main salary variable for later salary-based analysis."
      ],
      "id": "657180f6"
    },
    {
      "cell_type": "code",
      "metadata": {
        "message": false
      },
      "source": [
        "#| echo: true\n",
        "#| warning: false\n",
        "\n",
        "salary_availability = spark.sql(\"\"\"\n",
        "SELECT\n",
        "    CASE\n",
        "        WHEN salary IS NOT NULL\n",
        "             AND salary > 0\n",
        "        THEN 'Salary Available'\n",
        "        ELSE 'Salary Missing'\n",
        "    END AS salary_status,\n",
        "    COUNT(*) AS job_count,\n",
        "    ROUND(COUNT(*) / (SELECT COUNT(*) FROM job_postings) * 100, 2) AS job_share\n",
        "FROM job_postings\n",
        "GROUP BY\n",
        "    CASE\n",
        "        WHEN salary IS NOT NULL\n",
        "             AND salary > 0\n",
        "        THEN 'Salary Available'\n",
        "        ELSE 'Salary Missing'\n",
        "    END\n",
        "ORDER BY job_count DESC\n",
        "\"\"\").toPandas()\n",
        "\n",
        "display(style_table(salary_availability, {\n",
        "    \"job_count\": \"{:,.0f}\",\n",
        "    \"job_share\": \"{:.2f}%\"\n",
        "}))"
      ],
      "id": "df22b27a",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "message": false
      },
      "source": [
        "#| echo: true\n",
        "#| warning: false\n",
        "\n",
        "fig_salary = px.bar(\n",
        "    salary_availability,\n",
        "    x=\"salary_status\",\n",
        "    y=\"job_count\",\n",
        "    text=\"job_count\",\n",
        "    color=\"salary_status\",\n",
        "    color_discrete_map={\n",
        "        \"Salary Missing\": \"#EF553B\",\n",
        "        \"Salary Available\": \"#00CC96\"\n",
        "    },\n",
        "    title=\"Salary Availability After Imputation\",\n",
        "    labels={\n",
        "        \"salary_status\": \"\",\n",
        "        \"job_count\": \"Number of Job Postings\"\n",
        "    }\n",
        ")\n",
        "\n",
        "fig_salary.update_traces(\n",
        "    texttemplate=\"%{text:,.0f}\",\n",
        "    textposition=\"outside\",\n",
        "    marker_line_width=0\n",
        ")\n",
        "\n",
        "fig_salary.update_layout(\n",
        "    template=\"plotly_white\",\n",
        "    height=380,\n",
        "    margin=dict(l=50, r=40, t=70, b=50),\n",
        "    title=dict(x=0.02, xanchor=\"left\"),\n",
        "    showlegend=False,\n",
        "    font=dict(size=12),\n",
        "    yaxis=dict(gridcolor=\"rgba(0,0,0,0.08)\")\n",
        ")\n",
        "\n",
        "fig_salary.show()"
      ],
      "id": "255416a9",
      "execution_count": null,
      "outputs": []
